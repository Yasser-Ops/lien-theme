{%- style -%}
  .lien-qb {
    background-color: var(--lien-offwhite);
    border-top: 1px solid var(--lien-border);
  }

  .lien-qb__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-qb__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
      max-width: 900px;
    }
  }

  /* Header */
  .lien-qb__header {
    text-align: center;
    margin-bottom: var(--lien-space-2xl);
  }

  .lien-qb__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-qb__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-sm) 0;
  }

  .lien-qb__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    margin: 0;
  }

  /* Tier grid — adapts to any number of blocks */
  .lien-qb__tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 6px;
    margin-bottom: var(--lien-space-2xl);
    align-items: stretch;
  }

  @media screen and (min-width: 480px) {
    .lien-qb__tiers { gap: var(--lien-space-md); }
  }

  /* Tier card */
  .lien-qb__tier {
    position: relative;
    background-color: var(--lien-white);
    border: 2px solid var(--lien-border);
    padding: var(--lien-space-lg) var(--lien-space-xs) var(--lien-space-md);
    cursor: pointer;
    transition: border-color 200ms ease, background-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    text-align: center;
    user-select: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .lien-qb__tier:hover {
    border-color: var(--lien-accent-light);
  }

  .lien-qb__tier--active {
    border-color: var(--lien-accent);
    background-color: var(--lien-cream);
  }

  /* Featured: subtle lift so it reads as "recommended" before selection */
  .lien-qb__tier--featured {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: scale(1.02);
  }

  .lien-qb__tier--featured.lien-qb__tier--active {
    transform: scale(1.02);
  }

  /* Extra top padding when a badge is present */
  .lien-qb__tier--has-badge {
    padding-top: calc(var(--lien-space-xl) + 10px);
  }

  /* Badge */
  .lien-qb__tier-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--lien-accent);
    color: var(--lien-white);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 4px 14px;
    white-space: nowrap;
  }

  /* Optional tier image */
  .lien-qb__tier-img {
    width: 72px;
    height: 54px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .lien-qb__tier-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .lien-qb__tier:hover .lien-qb__tier-img img {
    transform: scale(1.05);
  }

  @media screen and (min-width: 480px) {
    .lien-qb__tier-img {
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 3;
    }
  }

  /* Tier text */
  .lien-qb__tier-qty {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lien-qb__tier-price {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-lg);
    color: var(--lien-dark);
    line-height: 1;
  }

  @media screen and (min-width: 480px) {
    .lien-qb__tier-price { font-size: var(--lien-text-2xl); }
  }

  .lien-qb__tier-original {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-qb__tier-save {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    color: var(--lien-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: rgba(123, 143, 166, 0.12);
    padding: 3px 10px;
  }

  /* Optional description & items — hidden on mobile to keep cards compact */
  .lien-qb__tier-desc {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-secondary);
    line-height: 1.5;
    margin: 0;
    display: none;
  }

  .lien-qb__tier-items {
    list-style: none;
    margin: 0;
    padding: var(--lien-space-xs) 0 0;
    border-top: 1px solid var(--lien-border-light);
    width: 100%;
    display: none;
    flex-direction: column;
    gap: 4px;
  }

  @media screen and (min-width: 480px) {
    .lien-qb__tier-desc  { display: block; }
    .lien-qb__tier-items { display: flex; }
  }

  .lien-qb__tier-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-secondary);
    text-align: left;
  }

  .lien-qb__item-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--lien-accent);
    flex-shrink: 0;
  }

  /* Per-set variant selector rows */
  .lien-qb__slots {
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-lg);
    margin-bottom: var(--lien-space-2xl);
  }

  .lien-qb__slot         { display: none; }
  .lien-qb__slot--visible { display: block; }

  .lien-qb__slot-label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--lien-space-sm) 0;
  }

  .lien-qb__color-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--lien-space-sm);
  }

  .lien-qb__color-btn {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-sm);
    color: var(--lien-text);
    background-color: var(--lien-white);
    border: 1px solid var(--lien-border);
    padding: 6px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 150ms ease, background-color 150ms ease, color 150ms ease;
  }

  .lien-qb__color-btn:hover { border-color: var(--lien-accent); }

  .lien-qb__color-btn--active {
    border-color: var(--lien-dark);
    background-color: var(--lien-dark);
    color: var(--lien-white);
  }

  .lien-qb__color-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  /* Running total */
  .lien-qb__summary {
    display: flex;
    align-items: center;
    gap: var(--lien-space-md);
    margin-bottom: var(--lien-space-lg);
    flex-wrap: wrap;
  }

  .lien-qb__total {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    color: var(--lien-dark);
  }

  .lien-qb__total-was {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-qb__total-saved {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-accent);
    background-color: rgba(123, 143, 166, 0.12);
    padding: 4px 12px;
    border-radius: var(--lien-radius-sm);
  }

  /* CTA */
  .lien-qb__btn {
    width: 100%;
    padding: 18px;
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--lien-dark);
    color: var(--lien-white);
    border: none;
    cursor: pointer;
    transition: background-color var(--lien-transition-base);
  }

  .lien-qb__btn:hover:not(:disabled) { background-color: var(--lien-dark-hover); }

  .lien-qb__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .lien-qb__hint {
    text-align: center;
    margin-top: var(--lien-space-sm);
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-muted);
  }
{%- endstyle -%}

{%- assign qb_product = section.settings.product -%}
{%- if qb_product == blank and product != blank -%}
  {%- assign qb_product = product -%}
{%- endif -%}

{%- if qb_product != blank and section.blocks.size > 0 -%}

{%- assign base_price = qb_product.selected_or_first_available_variant.price -%}

{%- comment -%} Determine how many slot rows to render (= highest qty among all blocks) {%- endcomment -%}
{%- assign max_qty = 1 -%}
{%- for block in section.blocks -%}
  {%- if block.settings.qty > max_qty -%}
    {%- assign max_qty = block.settings.qty -%}
  {%- endif -%}
{%- endfor -%}

{%- assign slot_label = section.settings.slot_label | default: 'Set' -%}

<section class="lien-qb" id="lien-qb-{{ section.id }}">
  <div class="lien-qb__inner">

    <div class="lien-qb__header">
      {%- if section.settings.label != blank -%}
        <span class="lien-qb__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lien-qb__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-qb__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-qb__tiers" role="radiogroup" aria-label="Select bundle size">
      {%- for block in section.blocks -%}
        {%- assign full_price  = base_price | times: block.settings.qty -%}
        {%- assign disc_cents  = full_price | times: block.settings.discount | divided_by: 100 -%}
        {%- assign final_price = full_price | minus: disc_cents -%}

        <div
          class="lien-qb__tier{% if block.settings.badge != blank %} lien-qb__tier--has-badge{% endif %}{% if block.settings.featured %} lien-qb__tier--featured{% endif %}{% if forloop.first %} lien-qb__tier--active{% endif %}"
          data-tier
          data-qty="{{ block.settings.qty }}"
          data-discount="{{ block.settings.discount }}"
          data-code="{{ block.settings.discount_code }}"
          role="radio"
          aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
          tabindex="0"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.badge != blank -%}
            <span class="lien-qb__tier-badge">{{ block.settings.badge }}</span>
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            <div class="lien-qb__tier-img">
              {{ block.settings.image | image_url: width: 400 | image_tag:
                loading: 'lazy',
                widths: '144, 280, 400',
                sizes: '(min-width: 480px) 30vw, 72px'
              }}
            </div>
          {%- endif -%}

          <span class="lien-qb__tier-qty">{{ block.settings.name }}</span>
          <span class="lien-qb__tier-price">{{ final_price | money }}</span>

          {%- if block.settings.discount > 0 -%}
            <span class="lien-qb__tier-original">{{ full_price | money }}</span>
            <span class="lien-qb__tier-save">Save {{ block.settings.discount }}%</span>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="lien-qb__tier-desc">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.items != blank -%}
            <ul class="lien-qb__tier-items">
              {%- assign items_arr = block.settings.items | split: ',' -%}
              {%- for item in items_arr -%}
                <li class="lien-qb__tier-item">
                  <span class="lien-qb__item-dot"></span>
                  {{ item | strip }}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="lien-qb__slots">
      {%- for slot_index in (1..max_qty) -%}
        <div
          class="lien-qb__slot{% if slot_index == 1 %} lien-qb__slot--visible{% endif %}"
          data-slot="{{ slot_index }}"
        >
          <p class="lien-qb__slot-label">{{ slot_label }} {{ slot_index }}</p>
          <div class="lien-qb__color-btns">
            {%- for variant in qb_product.variants -%}
              <button
                type="button"
                class="lien-qb__color-btn"
                data-slot-btn="{{ slot_index }}"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price }}"
                {%- unless variant.available -%}disabled{%- endunless -%}
              >{{ variant.option1 }}</button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="lien-qb__summary">
      <span class="lien-qb__total" data-total></span>
      <span class="lien-qb__total-was"   data-total-was   style="display:none"></span>
      <span class="lien-qb__total-saved" data-total-saved style="display:none"></span>
    </div>

    <button type="button" class="lien-qb__btn" id="lien-qb-btn-{{ section.id }}" disabled>
      Select a color to continue
    </button>

    {%- if section.settings.hint != blank -%}
      <p class="lien-qb__hint">{{ section.settings.hint }}</p>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var section    = document.getElementById('lien-qb-{{ section.id }}');
  var btn        = document.getElementById('lien-qb-btn-{{ section.id }}');
  var totalEl    = section.querySelector('[data-total]');
  var totalWas   = section.querySelector('[data-total-was]');
  var totalSaved = section.querySelector('[data-total-saved]');
  if (!section || !btn) return;

  var state = { qty: 1, discount: 0, code: '', slots: [null] };

  /* ── Tier selection ── */
  section.querySelectorAll('[data-tier]').forEach(function (tier) {
    tier.addEventListener('click', function () { selectTier(tier); });
    tier.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectTier(tier); }
    });
  });

  function selectTier(tierEl) {
    section.querySelectorAll('[data-tier]').forEach(function (t) {
      t.classList.remove('lien-qb__tier--active');
      t.setAttribute('aria-checked', 'false');
    });
    tierEl.classList.add('lien-qb__tier--active');
    tierEl.setAttribute('aria-checked', 'true');

    state.qty      = parseInt(tierEl.dataset.qty, 10);
    state.discount = parseInt(tierEl.dataset.discount || '0', 10);
    state.code     = tierEl.dataset.code || '';
    state.slots    = new Array(state.qty).fill(null);

    /* Reset all color selections */
    section.querySelectorAll('.lien-qb__color-btn--active').forEach(function (b) {
      b.classList.remove('lien-qb__color-btn--active');
    });

    /* Show only the slot rows needed for this tier's qty */
    section.querySelectorAll('[data-slot]').forEach(function (slotEl) {
      var num = parseInt(slotEl.dataset.slot, 10);
      slotEl.classList.toggle('lien-qb__slot--visible', num <= state.qty);
    });

    updateSummary();
    updateBtn();
  }

  /* ── Variant selection per slot ── */
  section.querySelectorAll('[data-slot-btn]').forEach(function (cb) {
    cb.addEventListener('click', function () {
      if (cb.disabled) return;
      var slot = parseInt(cb.dataset.slotBtn, 10) - 1;

      section.querySelectorAll('[data-slot-btn="' + cb.dataset.slotBtn + '"]').forEach(function (b) {
        b.classList.remove('lien-qb__color-btn--active');
      });
      cb.classList.add('lien-qb__color-btn--active');

      state.slots[slot] = {
        id:    parseInt(cb.dataset.variantId, 10),
        price: parseInt(cb.dataset.variantPrice, 10)
      };

      updateSummary();
      updateBtn();
    });
  });

  /* ── Running total ── */
  function money(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function updateSummary() {
    var picked = state.slots.filter(Boolean);
    if (!picked.length) { totalEl.textContent = ''; return; }

    var full = 0;
    picked.forEach(function (s) { full += s.price; });

    var disc  = Math.round(full * state.discount / 100);
    var final = full - disc;

    totalEl.textContent = money(final);

    if (state.discount > 0 && picked.length === state.qty) {
      totalWas.textContent   = money(full);
      totalSaved.textContent = 'You save ' + money(disc);
      totalWas.style.display   = '';
      totalSaved.style.display = '';
    } else {
      totalWas.style.display   = 'none';
      totalSaved.style.display = 'none';
    }
  }

  /* ── Button state ── */
  function updateBtn() {
    var missing = state.slots.filter(function (s) { return s === null; }).length;
    if (missing > 0) {
      btn.disabled    = true;
      btn.textContent = missing === state.qty
        ? 'Select a color to continue'
        : 'Select ' + missing + ' more color' + (missing > 1 ? 's' : '');
    } else {
      btn.disabled    = false;
      btn.textContent = 'Add ' + state.qty + (state.qty === 1 ? ' {{ slot_label }}' : ' {{ slot_label }}s') + ' to Cart';
    }
  }

  /* ── Add to cart → redirect to checkout ── */
  btn.addEventListener('click', function () {
    if (state.slots.some(function (s) { return s === null; })) return;

    btn.disabled    = true;
    btn.textContent = 'Adding…';

    var items = state.slots.map(function (s) { return { id: s.id, quantity: 1 }; });

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body:    JSON.stringify({ items: items })
    })
    .then(function (res) {
      if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Cart error'); });
      return res.json();
    })
    .then(function () {
      window.location.href = state.code
        ? '/checkout?discount=' + encodeURIComponent(state.code)
        : '/checkout';
    })
    .catch(function (err) {
      console.error('[Lien QB]', err);
      btn.disabled = false;
      updateBtn();
    });
  });

  /* ── Init: activate the first tier ── */
  var firstTier = section.querySelector('[data-tier]');
  if (firstTier) selectTier(firstTier);
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Quantity Breaks",
  "tag": "section",
  "class": "lien-qb-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave blank on a product page — the current product is used automatically."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Save More"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy More, Save More"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Stock up on sets — for you, your partner, or as gifts."
    },
    {
      "type": "text",
      "id": "slot_label",
      "label": "Slot label",
      "default": "Set",
      "info": "Label for each variant-picker row, e.g. 'Set', 'Bracelet', 'Item'."
    },
    {
      "type": "text",
      "id": "hint",
      "label": "Hint text below button",
      "default": "Discount applied automatically at checkout"
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "info": "e.g. Most Popular — leave blank to hide"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured",
          "default": false,
          "info": "Adds gold border and gold button"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Bundle name",
          "default": "1 Set"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Included items (comma-separated)",
          "info": "e.g. 2 × Magnetic Couple Bracelet Set, Premium gift box"
        },
        {
          "type": "number",
          "id": "bundle_qty",
          "label": "Bundle quantity",
          "default": 1,
          "info": "Passed as ?bundle=N in the URL so Pumper can auto-select the right offer"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Display price",
          "default": "$20",
          "info": "Match this to what you configured in Pumper"
        },
        {
          "type": "text",
