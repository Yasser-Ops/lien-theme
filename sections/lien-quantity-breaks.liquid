{%- style -%}
  /* ======================================================================
     Lien Quantity Breaks
     Buy More, Save More — tier selector + single variant color picker
     ====================================================================== */

  .lien-qb {
    background-color: var(--lien-offwhite);
    border-top: 1px solid var(--lien-border);
  }

  .lien-qb__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-qb__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
      max-width: 860px;
    }
  }

  /* Header */
  .lien-qb__header {
    text-align: center;
    margin-bottom: var(--lien-space-2xl);
  }

  .lien-qb__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-qb__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-sm) 0;
  }

  .lien-qb__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    margin: 0;
  }

  /* Tier selector */
  .lien-qb__tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--lien-space-md);
    margin-top: 18px;
    margin-bottom: var(--lien-space-2xl);
  }

  .lien-qb__tier {
    position: relative;
    background-color: var(--lien-white);
    border: 2px solid var(--lien-border);
    padding: var(--lien-space-xl) var(--lien-space-md) var(--lien-space-lg);
    cursor: pointer;
    transition: border-color 200ms ease, background-color 200ms ease;
    text-align: center;
    user-select: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .lien-qb__tier:hover {
    border-color: var(--lien-accent-light);
  }

  .lien-qb__tier--active {
    border-color: var(--lien-accent);
    background-color: var(--lien-cream);
  }

  .lien-qb__tier--popular {
    border-color: var(--lien-accent);
    padding-top: calc(var(--lien-space-xl) + 8px);
  }

  .lien-qb__tier-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--lien-accent);
    color: var(--lien-white);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 4px 14px;
    white-space: nowrap;
  }

  .lien-qb__tier-qty {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lien-qb__tier-price {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    color: var(--lien-dark);
    line-height: 1;
  }

  .lien-qb__tier-original {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-qb__tier-save {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    color: var(--lien-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: rgba(123, 143, 166, 0.12);
    padding: 3px 10px;
  }

  /* Color picker */
  .lien-qb__color-row {
    margin-bottom: var(--lien-space-2xl);
  }

  .lien-qb__color-heading {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-sm) 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lien-qb__color-heading span {
    font-weight: var(--lien-weight-normal);
    color: var(--lien-text-secondary);
    text-transform: none;
    letter-spacing: 0;
  }

  .lien-qb__swatches {
    display: flex;
    gap: var(--lien-space-sm);
    flex-wrap: wrap;
  }

  .lien-qb__swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all var(--lien-transition-base);
    outline: none;
    position: relative;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.12);
    background-color: #ccc;
  }

  .lien-qb__swatch:hover {
    transform: scale(1.12);
    box-shadow: 0 0 0 2px var(--lien-accent-light);
  }

  .lien-qb__swatch--active {
    box-shadow: 0 0 0 2px var(--lien-white), 0 0 0 4px var(--lien-accent);
    transform: scale(1.08);
  }

  .lien-qb__swatch:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  /* Summary row */
  .lien-qb__summary {
    display: flex;
    align-items: center;
    gap: var(--lien-space-md);
    margin-bottom: var(--lien-space-lg);
    flex-wrap: wrap;
  }

  .lien-qb__total {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    color: var(--lien-dark);
  }

  .lien-qb__total-was {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-qb__total-saved {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-accent);
    background-color: rgba(123, 143, 166, 0.12);
    padding: 4px 12px;
    border-radius: var(--lien-radius-sm);
  }

  /* CTA */
  .lien-qb__btn {
    width: 100%;
    padding: 18px;
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background-color: var(--lien-dark);
    color: var(--lien-white);
    border: none;
    cursor: pointer;
    transition: all var(--lien-transition-base);
  }

  .lien-qb__btn:hover:not(:disabled) {
    background-color: var(--lien-dark-hover);
  }

  .lien-qb__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .lien-qb__hint {
    text-align: center;
    margin-top: var(--lien-space-sm);
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-text-muted);
  }
{%- endstyle -%}

{%- assign qb_product = section.settings.product -%}
{%- if qb_product == blank and product != blank -%}
  {%- assign qb_product = product -%}
{%- endif -%}

{%- if qb_product != blank -%}

{%- assign base_price = qb_product.selected_or_first_available_variant.price -%}
{%- assign d2 = section.settings.discount_2 -%}
{%- assign d3 = section.settings.discount_3 -%}
{%- assign price_2_full = base_price | times: 2 -%}
{%- assign price_2_disc = price_2_full | times: d2 | divided_by: 100 -%}
{%- assign price_2_final = price_2_full | minus: price_2_disc -%}
{%- assign price_3_full = base_price | times: 3 -%}
{%- assign price_3_disc = price_3_full | times: d3 | divided_by: 100 -%}
{%- assign price_3_final = price_3_full | minus: price_3_disc -%}

<section class="lien-qb" id="lien-qb-{{ section.id }}" data-lien-qb>
  <div class="lien-qb__inner">

    <div class="lien-qb__header">
      <span class="lien-qb__label">{{ section.settings.label }}</span>
      <h2 class="lien-qb__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-qb__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-qb__tiers" role="radiogroup" aria-label="Select bundle size">

      <div class="lien-qb__tier lien-qb__tier--active"
        data-tier data-qty="1" data-discount="0" data-code=""
        role="radio" aria-checked="true" tabindex="0">
        <span class="lien-qb__tier-qty">1 Set</span>
        <span class="lien-qb__tier-price">{{ base_price | money }}</span>
      </div>

      <div class="lien-qb__tier lien-qb__tier--popular"
        data-tier data-qty="2" data-discount="{{ d2 }}" data-code="{{ section.settings.code_2 }}"
        role="radio" aria-checked="false" tabindex="0">
        <span class="lien-qb__tier-badge">Most Popular</span>
        <span class="lien-qb__tier-qty">2 Sets</span>
        <span class="lien-qb__tier-price">{{ price_2_final | money }}</span>
        <span class="lien-qb__tier-original">{{ price_2_full | money }}</span>
        <span class="lien-qb__tier-save">Save {{ d2 }}%</span>
      </div>

      <div class="lien-qb__tier"
        data-tier data-qty="3" data-discount="{{ d3 }}" data-code="{{ section.settings.code_3 }}"
        role="radio" aria-checked="false" tabindex="0">
        <span class="lien-qb__tier-qty">3 Sets</span>
        <span class="lien-qb__tier-price">{{ price_3_final | money }}</span>
        <span class="lien-qb__tier-original">{{ price_3_full | money }}</span>
        <span class="lien-qb__tier-save">Save {{ d3 }}%</span>
      </div>

    </div>

    <div class="lien-qb__color-row">
      <p class="lien-qb__color-heading">
        Color: <span id="lien-qb-color-name-{{ section.id }}">—</span>
      </p>
      <div class="lien-qb__swatches">
        {%- for variant in qb_product.variants -%}
          {%- liquid
            assign color_lower = variant.option1 | downcase | strip
            assign bg_color = '#aaaaaa'
            if color_lower == 'black'
              assign bg_color = '#1a1c22'
            elsif color_lower == 'pink'
              assign bg_color = '#e8a4b8'
            elsif color_lower == 'white'
              assign bg_color = '#f0eeec'
            elsif color_lower == 'blue'
              assign bg_color = '#7b9ec4'
            elsif color_lower == 'beige'
              assign bg_color = '#d4c4a8'
            elsif color_lower == 'gray' or color_lower == 'grey'
              assign bg_color = '#9ca3af'
            elsif color_lower == 'green'
              assign bg_color = '#81b29a'
            elsif color_lower == 'yellow'
              assign bg_color = '#f9e07f'
            elsif color_lower == 'red'
              assign bg_color = '#e57373'
            elsif color_lower == 'purple'
              assign bg_color = '#b39ddb'
            endif
          -%}
          <button
            type="button"
            class="lien-qb__swatch"
            data-variant-id="{{ variant.id }}"
            data-variant-price="{{ variant.price }}"
            aria-label="{{ variant.option1 | escape }}"
            title="{{ variant.option1 | escape }}"
            {%- if variant.featured_image != blank -%}
              style="background-image:url('{{ variant.featured_image | image_url: width: 80 }}');background-size:cover;background-position:center;"
            {%- else -%}
              style="background-color:{{ bg_color }};"
            {%- endif -%}
            {%- unless variant.available -%}disabled{%- endunless -%}
          ></button>
        {%- endfor -%}
      </div>
    </div>

    <div class="lien-qb__summary">
      <span class="lien-qb__total" data-total></span>
      <span class="lien-qb__total-was" data-total-was style="display:none"></span>
      <span class="lien-qb__total-saved" data-total-saved style="display:none"></span>
    </div>

    <button type="button" class="lien-qb__btn" id="lien-qb-btn-{{ section.id }}" disabled>
      Select a color to continue
    </button>

    <p class="lien-qb__hint">Discount applied automatically at checkout</p>

  </div>
</section>

<script>
(function () {
  var section    = document.getElementById('lien-qb-{{ section.id }}');
  var btn        = document.getElementById('lien-qb-btn-{{ section.id }}');
  var nameEl     = document.getElementById('lien-qb-color-name-{{ section.id }}');
  var totalEl    = section.querySelector('[data-total]');
  var totalWas   = section.querySelector('[data-total-was]');
  var totalSaved = section.querySelector('[data-total-saved]');
  if (!section) return;

  var state = { qty: 1, discount: 0, code: '', variantId: null, variantPrice: 0 };

  /* ── Tier selection ─────────────────────────────────────── */
  section.querySelectorAll('[data-tier]').forEach(function (tier) {
    tier.addEventListener('click', function () { selectTier(tier); });
    tier.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectTier(tier); }
    });
  });

  function selectTier(tierEl) {
    section.querySelectorAll('[data-tier]').forEach(function (t) {
      t.classList.remove('lien-qb__tier--active');
      t.setAttribute('aria-checked', 'false');
    });
    tierEl.classList.add('lien-qb__tier--active');
    tierEl.setAttribute('aria-checked', 'true');
    state.qty      = parseInt(tierEl.dataset.qty, 10);
    state.discount = parseInt(tierEl.dataset.discount || '0', 10);
    state.code     = tierEl.dataset.code || '';
    updateSummary();
    updateBtn();
  }

  /* ── Color selection ────────────────────────────────────── */
  section.querySelectorAll('.lien-qb__swatch').forEach(function (sw) {
    sw.addEventListener('click', function () {
      section.querySelectorAll('.lien-qb__swatch').forEach(function (s) {
        s.classList.remove('lien-qb__swatch--active');
      });
      sw.classList.add('lien-qb__swatch--active');
      state.variantId    = parseInt(sw.dataset.variantId, 10);
      state.variantPrice = parseInt(sw.dataset.variantPrice, 10);
      if (nameEl) nameEl.textContent = sw.title;
      updateSummary();
      updateBtn();
    });
  });

  /* ── Summary ────────────────────────────────────────────── */
  function money(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function updateSummary() {
    if (!state.variantId) return;
    var full  = state.variantPrice * state.qty;
    var disc  = Math.round(full * state.discount / 100);
    var final = full - disc;
    totalEl.textContent = money(final);
    if (state.discount > 0) {
      totalWas.textContent   = money(full);
      totalSaved.textContent = 'You save ' + money(disc);
      totalWas.style.display   = '';
      totalSaved.style.display = '';
    } else {
      totalWas.style.display   = 'none';
      totalSaved.style.display = 'none';
    }
  }

  /* ── Button state ───────────────────────────────────────── */
  function updateBtn() {
    if (!state.variantId) {
      btn.disabled    = true;
      btn.textContent = 'Select a color to continue';
      return;
    }
    btn.disabled    = false;
    btn.textContent = 'Add ' + state.qty + (state.qty === 1 ? ' Set' : ' Sets') + ' to Cart';
  }

  /* ── Add to cart ────────────────────────────────────────── */
  btn.addEventListener('click', function () {
    if (!state.variantId) return;
    btn.disabled    = true;
    btn.textContent = 'Adding…';

    var items = [];
    for (var i = 0; i < state.qty; i++) {
      items.push({ id: state.variantId, quantity: 1 });
    }

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body:    JSON.stringify({ items: items })
    })
    .then(function (res) {
      if (!res.ok) return res.json().then(function (d) { throw new Error(d.description || 'Cart error'); });
      return res.json();
    })
    .then(function () {
      var dest = state.code
        ? '/checkout?discount=' + encodeURIComponent(state.code)
        : '/checkout';
      window.location.href = dest;
    })
    .catch(function (err) {
      console.error('[Lien QB]', err);
      btn.disabled = false;
      updateBtn();
    });
  });

  /* ── Init ───────────────────────────────────────────────── */
  var firstTier = section.querySelector('[data-tier]');
  if (firstTier) selectTier(firstTier);
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Quantity Breaks",
  "tag": "section",
  "class": "lien-qb-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave blank on the product page — uses the current product automatically."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Save More"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy More, Save More"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Stock up on sets — for you, your partner, or as gifts."
    },
    {
      "type": "range",
      "id": "discount_2",
      "label": "Discount for 2 sets (%)",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "discount_3",
      "label": "Discount for 3 sets (%)",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 15
    },
    {
      "type": "text",
      "id": "code_2",
      "label": "Discount code — 2 sets",
      "default": "BUNDLE2",
      "info": "Must match a real code in your Shopify discounts"
    },
    {
      "type": "text",
      "id": "code_3",
      "label": "Discount code — 3 sets",
      "default": "BUNDLE3",
      "info": "Must match a real code in your Shopify discounts"
    }
  ],
  "blocks": [],
  "presets": [
    { "name": "Quantity Breaks" }
  ]
}
{% endschema %}
