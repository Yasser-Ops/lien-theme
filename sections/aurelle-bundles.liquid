{%- style -%}
  /* ======================================================================
     Aurelle Bundles
     Product bundle showcase with value pricing
     ====================================================================== */

  .aurelle-bundles {
    background-color: var(--aurelle-cream);
  }

  .aurelle-bundles__inner {
    max-width: var(--aurelle-container-max);
    margin: 0 auto;
    padding: var(--aurelle-section-padding-mobile) var(--aurelle-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .aurelle-bundles__inner {
      padding: var(--aurelle-section-padding-desktop) var(--aurelle-container-padding);
    }
  }

  .aurelle-bundles__header {
    text-align: center;
    margin-bottom: var(--aurelle-space-3xl);
  }

  .aurelle-bundles__label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aurelle-gold);
    display: block;
    margin-bottom: var(--aurelle-space-sm);
  }

  .aurelle-bundles__title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--aurelle-text);
    margin: 0 0 var(--aurelle-space-md) 0;
  }

  .aurelle-bundles__subtitle {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-md);
    color: var(--aurelle-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Grid */
  .aurelle-bundles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--aurelle-space-lg);
    align-items: start;
  }

  @media screen and (min-width: 640px) {
    .aurelle-bundles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .aurelle-bundles__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .aurelle-bundles__card {
    background-color: var(--aurelle-white);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all var(--aurelle-transition-base);
  }

  .aurelle-bundles__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--aurelle-shadow-lg);
  }

  .aurelle-bundles__card--featured {
    border: 2px solid var(--aurelle-gold);
    transform: scale(1.02);
  }

  .aurelle-bundles__card--featured:hover {
    transform: scale(1.02) translateY(-4px);
  }

  /* Badge */
  .aurelle-bundles__badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    white-space: nowrap;
  }

  /* Image */
  .aurelle-bundles__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--aurelle-cream);
  }

  .aurelle-bundles__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--aurelle-transition-slow);
  }

  .aurelle-bundles__card:hover .aurelle-bundles__image img {
    transform: scale(1.03);
  }

  /* Image placeholder */
  .aurelle-bundles__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--aurelle-cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurelle-text-muted);
  }

  .aurelle-bundles__image-placeholder svg {
    width: 48px;
    height: 48px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1;
    opacity: 0.4;
  }

  /* Body */
  .aurelle-bundles__body {
    padding: var(--aurelle-space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-md);
  }

  .aurelle-bundles__name {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-xl);
    color: var(--aurelle-text);
    margin: 0;
    line-height: 1.2;
  }

  .aurelle-bundles__description {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-base);
    color: var(--aurelle-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Items list */
  .aurelle-bundles__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-xs);
    padding-top: var(--aurelle-space-sm);
    border-top: 1px solid var(--aurelle-border-light);
  }

  .aurelle-bundles__item {
    display: flex;
    align-items: center;
    gap: var(--aurelle-space-sm);
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-base);
    color: var(--aurelle-text-secondary);
  }

  .aurelle-bundles__item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--aurelle-gold);
    flex-shrink: 0;
  }

  /* Pricing */
  .aurelle-bundles__pricing {
    display: flex;
    align-items: center;
    gap: var(--aurelle-space-md);
    flex-wrap: wrap;
  }

  .aurelle-bundles__price {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-2xl);
    color: var(--aurelle-dark);
  }

  .aurelle-bundles__price-original {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-md);
    color: var(--aurelle-text-muted);
    text-decoration: line-through;
  }

  .aurelle-bundles__savings {
    background-color: rgba(184, 149, 106, 0.12);
    color: var(--aurelle-gold);
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: var(--aurelle-radius-sm);
  }

  /* CTA */
  .aurelle-bundles__cta {
    margin-top: auto;
  }

  .aurelle-bundles__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 16px;
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all var(--aurelle-transition-base);
  }

  .aurelle-bundles__btn--gold {
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
  }

  .aurelle-bundles__btn--gold:hover {
    background-color: var(--aurelle-gold-hover);
  }

  .aurelle-bundles__btn--dark {
    background-color: var(--aurelle-dark);
    color: var(--aurelle-white);
  }

  .aurelle-bundles__btn--dark:hover {
    background-color: var(--aurelle-dark-hover);
  }

  .aurelle-bundles__btn--outline {
    background-color: transparent;
    color: var(--aurelle-dark);
    border: 1.5px solid var(--aurelle-dark);
  }

  .aurelle-bundles__btn--outline:hover {
    background-color: var(--aurelle-dark);
    color: var(--aurelle-white);
  }
{%- endstyle -%}

<section class="aurelle-bundles" id="aurelle-bundles-{{ section.id }}">
  <div class="aurelle-bundles__inner">

    <div class="aurelle-bundles__header">
      {%- if section.settings.label != blank -%}
        <span class="aurelle-bundles__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="aurelle-bundles__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="aurelle-bundles__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="aurelle-bundles__grid">
      {%- for block in section.blocks -%}
        {%- assign btn_style = 'dark' -%}
        {%- if block.settings.featured -%}{%- assign btn_style = 'gold' -%}{%- endif -%}

        <div
          class="aurelle-bundles__card{% if block.settings.featured %} aurelle-bundles__card--featured{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.badge != blank -%}
            <div class="aurelle-bundles__badge">{{ block.settings.badge }}</div>
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            <div class="aurelle-bundles__image">
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw'
              }}
            </div>
          {%- else -%}
            <div class="aurelle-bundles__image-placeholder">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {%- endif -%}

          <div class="aurelle-bundles__body">
            <h3 class="aurelle-bundles__name">{{ block.settings.name }}</h3>

            {%- if block.settings.description != blank -%}
              <p class="aurelle-bundles__description">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if block.settings.items != blank -%}
              <ul class="aurelle-bundles__items">
                {%- assign items_list = block.settings.items | split: ',' -%}
                {%- for item in items_list -%}
                  <li class="aurelle-bundles__item">
                    <span class="aurelle-bundles__item-dot"></span>
                    {{ item | strip }}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="aurelle-bundles__pricing">
              <span class="aurelle-bundles__price">{{ block.settings.price }}</span>
              {%- if block.settings.original_price != blank -%}
                <span class="aurelle-bundles__price-original">{{ block.settings.original_price }}</span>
              {%- endif -%}
              {%- if block.settings.savings_label != blank -%}
                <span class="aurelle-bundles__savings">{{ block.settings.savings_label }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.button_label != blank -%}
              <div class="aurelle-bundles__cta">
                <a
                  href="{{ block.settings.button_link }}"
                  class="aurelle-bundles__btn aurelle-bundles__btn--{{ btn_style }}"
                >
                  {{ block.settings.button_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Aurelle Bundles",
  "tag": "section",
  "class": "aurelle-bundles-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Save More"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bundle & Save"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Stock up and save. The more you invest in your skin, the more you save."
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. Most Popular)",
          "info": "Appears as a pill at the top of the card. Leave blank to hide."
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured bundle",
          "default": false,
          "info": "Adds gold border and gold CTA button"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Bundle name",
          "default": "1 Bottle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "Start your Aurelle ritual. Perfect for first-timers."
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Included items (comma-separated)",
          "default": "1 × Aurelle Serum (30ml)",
          "info": "Separate each item with a comma"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Bundle price",
          "default": "$30"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original price (crossed out)",
          "info": "Leave blank for single-quantity option"
        },
        {
          "type": "text",
          "id": "savings_label",
          "label": "Savings label",
          "info": "e.g. Save $5 — leave blank to hide"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Add to Cart"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aurelle Bundles",
      "blocks": [
        {
          "type": "bundle",
          "settings": {
            "name": "1 Bottle",
            "description": "Start your Aurelle ritual. Perfect for first-timers who want to experience the difference.",
            "items": "1 × Aurelle Serum (30ml)",
            "price": "$30",
            "savings_label": "",
            "button_label": "Add to Cart",
            "featured": false
          }
        },
        {
          "type": "bundle",
          "settings": {
            "badge": "Most Popular",
            "name": "2 Bottles",
            "description": "The smart choice. Two months of radiant skin — and you save on every bottle.",
            "items": "2 × Aurelle Serum (30ml)",
            "price": "$55",
            "original_price": "$60",
            "savings_label": "Save $5",
            "button_label": "Add to Cart",
            "featured": true
          }
        },
        {
          "type": "bundle",
          "settings": {
            "name": "3 Bottles",
            "description": "Commit to your glow. Stock up and enjoy the biggest saving per bottle.",
            "items": "3 × Aurelle Serum (30ml)",
            "price": "$80",
            "original_price": "$90",
            "savings_label": "Save $10",
            "button_label": "Add to Cart",
            "featured": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
