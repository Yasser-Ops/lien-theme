{%- style -%}
  /* ======================================================================
     Lien Comparison Table
     Lien vs. typical skincare brands
     ====================================================================== */

  .lien-comparison {
    background-color: var(--lien-offwhite);
  }

  .lien-comparison__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-comparison__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
    }
  }

  .lien-comparison__header {
    text-align: center;
    margin-bottom: var(--lien-space-3xl);
  }

  .lien-comparison__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-comparison__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-comparison__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Table wrapper */
  .lien-comparison__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .lien-comparison__table {
    width: 100%;
    min-width: 560px;
    border-collapse: collapse;
  }

  /* Column headers */
  .lien-comparison__thead th {
    padding: var(--lien-space-md) var(--lien-space-xl);
    text-align: center;
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .lien-comparison__thead th:first-child {
    text-align: left;
    color: var(--lien-text-muted);
  }

  .lien-comparison__col-lien {
    background-color: var(--lien-dark);
    color: var(--lien-offwhite) !important;
    border-radius: 12px 12px 0 0;
    position: relative;
  }

  .lien-comparison__col-lien::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--lien-accent);
    border-bottom: none;
    border-radius: 12px 12px 0 0;
    pointer-events: none;
  }

  .lien-comparison__col-others {
    color: var(--lien-text-muted) !important;
  }

  /* Rows */
  .lien-comparison__row td {
    padding: var(--lien-space-md) var(--lien-space-xl);
    text-align: center;
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    border-bottom: 1px solid var(--lien-border-light);
  }

  .lien-comparison__row td:first-child {
    text-align: left;
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-medium);
    font-size: var(--lien-text-md);
    color: var(--lien-text);
  }

  .lien-comparison__row:last-child td {
    border-bottom: none;
  }

  /* Lien column body cells */
  .lien-comparison__row td.lien-comparison__cell-lien {
    background-color: rgba(28, 28, 28, 0.04);
    position: relative;
    font-weight: var(--lien-weight-semibold);
    color: var(--lien-dark);
  }

  .lien-comparison__row td.lien-comparison__cell-lien::after {
    content: '';
    position: absolute;
    inset: 0;
    border-left: 2px solid var(--lien-accent);
    border-right: 2px solid var(--lien-accent);
    pointer-events: none;
  }

  /* Last row Lien cell gets bottom border */
  .lien-comparison__row:last-child td.lien-comparison__cell-lien::after {
    border-bottom: 2px solid var(--lien-accent);
    border-radius: 0 0 12px 12px;
  }

  /* Icons */
  .lien-comparison__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }

  .lien-comparison__icon--check {
    background-color: rgba(184, 149, 106, 0.12);
    color: var(--lien-accent);
  }

  .lien-comparison__icon--no {
    background-color: rgba(200, 80, 80, 0.08);
    color: #C85050;
  }

  .lien-comparison__icon--partial {
    background-color: rgba(180, 150, 80, 0.1);
    color: #B49650;
  }

  .lien-comparison__icon svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* CTA below table */
  .lien-comparison__cta {
    text-align: center;
    margin-top: var(--lien-space-3xl);
  }

  .lien-comparison__cta-text {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    margin-bottom: var(--lien-space-lg);
  }
{%- endstyle -%}

<section class="lien-comparison" id="lien-comparison-{{ section.id }}">
  <div class="lien-comparison__inner">

    <div class="lien-comparison__header">
      {%- if section.settings.label != blank -%}
        <span class="lien-comparison__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lien-comparison__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-comparison__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-comparison__table-wrap">
      <table class="lien-comparison__table">
        <thead class="lien-comparison__thead">
          <tr>
            <th></th>
            <th class="lien-comparison__col-lien">{{ section.settings.col_lien | default: 'Lien' }}</th>
            <th class="lien-comparison__col-others">{{ section.settings.col_others | default: 'Typical Brands' }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            <tr class="lien-comparison__row" {{ block.shopify_attributes }}>
              <td>{{ block.settings.feature }}</td>
              <td class="lien-comparison__cell-lien">
                {%- if block.settings.lien_value != blank -%}
                  {{ block.settings.lien_value }}
                {%- elsif block.settings.lien_check -%}
                  <span class="lien-comparison__icon lien-comparison__icon--check">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                {%- else -%}
                  <span class="lien-comparison__icon lien-comparison__icon--no">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- endif -%}
              </td>
              <td>
                {%- if block.settings.others_value != blank -%}
                  {{ block.settings.others_value }}
                {%- elsif block.settings.others_partial -%}
                  <span class="lien-comparison__icon lien-comparison__icon--partial">
                    <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </span>
                {%- else -%}
                  <span class="lien-comparison__icon lien-comparison__icon--no">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </span>
                {%- endif -%}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="lien-comparison__cta">
        {%- if section.settings.cta_subtext != blank -%}
          <p class="lien-comparison__cta-text">{{ section.settings.cta_subtext }}</p>
        {%- endif -%}
        <a href="{{ section.settings.cta_link }}" class="lien-btn lien-btn--accent lien-btn--lg">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Lien Comparison",
  "tag": "section",
  "class": "lien-comparison-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lien vs. The Rest"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Not all skincare is created equal. Here's why Lien stands apart."
    },
    {
      "type": "text",
      "id": "col_lien",
      "label": "Lien column label",
      "default": "Lien"
    },
    {
      "type": "text",
      "id": "col_others",
      "label": "Others column label",
      "default": "Typical Brands"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA subtext",
      "default": "Ready to experience the Lien difference?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Clean Ingredients"
        },
        {
          "type": "header",
          "content": "Lien column"
        },
        {
          "type": "checkbox",
          "id": "lien_check",
          "label": "Show checkmark",
          "default": true,
          "info": "Overridden if custom value is set"
        },
        {
          "type": "text",
          "id": "lien_value",
          "label": "Custom value (optional)",
          "info": "Leave blank to use checkmark/X icon"
        },
        {
          "type": "header",
          "content": "Others column"
        },
        {
          "type": "checkbox",
          "id": "others_partial",
          "label": "Show partial (—) instead of X",
          "default": false
        },
        {
          "type": "text",
          "id": "others_value",
          "label": "Custom value (optional)",
          "info": "Leave blank to use X or partial icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien Comparison",
      "blocks": [
        { "type": "row", "settings": { "feature": "Clean, Transparent Ingredients", "lien_check": true, "others_partial": true } },
        { "type": "row", "settings": { "feature": "Dermatologist Tested & Approved", "lien_check": true, "others_partial": false } },
        { "type": "row", "settings": { "feature": "Cruelty-Free & Vegan Formula", "lien_check": true, "others_partial": false } },
        { "type": "row", "settings": { "feature": "No Harsh Chemicals or Parabens", "lien_check": true, "others_partial": false } },
        { "type": "row", "settings": { "feature": "30-Day Money-Back Guarantee", "lien_check": true, "others_partial": false } },
        { "type": "row", "settings": { "feature": "Sustainably Sourced & Packaged", "lien_check": true, "others_partial": true } }
      ]
    }
  ]
}
{% endschema %}
