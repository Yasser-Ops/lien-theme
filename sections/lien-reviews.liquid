{%- style -%}
  /* ======================================================================
     Lien Reviews
     Social proof review cards
     ====================================================================== */

  .lien-reviews {
    background-color: var(--lien-cream);
  }

  .lien-reviews__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-reviews__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
    }
  }

  .lien-reviews__header {
    text-align: center;
    margin-bottom: var(--lien-space-3xl);
  }

  .lien-reviews__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-reviews__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-reviews__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Card Grid */
  .lien-reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lien-space-lg);
  }

  @media screen and (min-width: 768px) {
    .lien-reviews__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--lien-space-xl);
    }
  }

  /* Mobile horizontal scroll */
  @media screen and (max-width: 767px) {
    .lien-reviews__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: var(--lien-space-md);
      padding-bottom: var(--lien-space-md);
      scrollbar-width: none;
    }

    .lien-reviews__grid::-webkit-scrollbar {
      display: none;
    }

    .lien-reviews__card {
      min-width: 85vw;
      scroll-snap-align: start;
      flex-shrink: 0;
    }
  }

  .lien-reviews__card {
    background-color: var(--lien-white);
    padding: var(--lien-space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-md);
    transition: all var(--lien-transition-base);
  }

  .lien-reviews__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--lien-shadow-lg);
  }

  /* Stars */
  .lien-reviews__stars {
    display: flex;
    gap: 3px;
  }

  .lien-reviews__star {
    width: 16px;
    height: 16px;
    color: var(--lien-accent);
  }

  .lien-reviews__star--empty {
    color: var(--lien-border);
  }

  .lien-reviews__star svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  /* Review text */
  .lien-reviews__text {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    margin: 0;
    flex-grow: 1;
  }

  /* Reviewer info */
  .lien-reviews__reviewer {
    display: flex;
    align-items: center;
    gap: var(--lien-space-sm);
    padding-top: var(--lien-space-md);
    border-top: 1px solid var(--lien-border-light);
  }

  .lien-reviews__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--lien-cream);
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lien-reviews__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lien-reviews__avatar-initial {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-accent);
  }

  .lien-reviews__name {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    color: var(--lien-text);
  }

  .lien-reviews__verified {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: var(--lien-accent);
  }

  .lien-reviews__verified svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }
{%- endstyle -%}

<section class="lien-reviews" id="lien-reviews-{{ section.id }}">
  <div class="lien-reviews__inner">
    <div class="lien-reviews__header">
      {%- if section.settings.label != blank -%}
        <span class="lien-reviews__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lien-reviews__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-reviews__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-reviews__grid">
      {%- for block in section.blocks -%}
        <div class="lien-reviews__card" {{ block.shopify_attributes }}>
          {%- comment -%} Star Rating {%- endcomment -%}
          <div class="lien-reviews__stars">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..5) -%}
              <span class="lien-reviews__star {% if i > rating %}lien-reviews__star--empty{% endif %}">
                <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </span>
            {%- endfor -%}
          </div>

          {%- comment -%} Review Text {%- endcomment -%}
          <p class="lien-reviews__text">"{{ block.settings.review_text }}"</p>

          {%- comment -%} Reviewer {%- endcomment -%}
          <div class="lien-reviews__reviewer">
            <div class="lien-reviews__avatar">
              {%- if block.settings.avatar != blank -%}
                {{ block.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <span class="lien-reviews__avatar-initial">{{ block.settings.name | slice: 0 | upcase }}</span>
              {%- endif -%}
            </div>
            <div>
              <div class="lien-reviews__name">{{ block.settings.name }}</div>
              {%- if block.settings.verified -%}
                <span class="lien-reviews__verified">
                  <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                  Verified Purchase
                </span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lien Reviews",
  "tag": "section",
  "class": "lien-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Real Couples"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Couples Say"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Join 50,000+ couples who wear their bond every day."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Sarah M."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "I've never felt so confident in my skin. The results are truly visible."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified purchase",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Camille & Nico",
            "rating": 5,
            "review_text": "We ordered these for our anniversary and I cried when we opened the box. The quality is so much better than I expected. We wear them every single day now.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Jade R.",
            "rating": 5,
            "review_text": "Long distance relationship and these bracelets make it feel like he's right here. The magnetic snap is so satisfying. 10/10 would buy again for every couple I know.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Marcus T.",
            "rating": 5,
            "review_text": "Bought this as a gift and she absolutely loved it. The packaging alone is worth it. We matched them up the moment she opened the box. Such a simple but powerful idea.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
