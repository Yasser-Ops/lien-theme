{%- style -%}
  /* ======================================================================
     Lien How It Works
     Numbered step cards
     ====================================================================== */

  .lien-how-it-works {
    background-color: var(--lien-white);
  }

  .lien-how-it-works__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-how-it-works__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
    }
  }

  .lien-how-it-works__header {
    text-align: center;
    margin-bottom: var(--lien-space-3xl);
  }

  .lien-how-it-works__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-how-it-works__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-how-it-works__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  .lien-how-it-works__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lien-space-xl);
  }

  @media screen and (min-width: 768px) {
    .lien-how-it-works__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
      gap: var(--lien-space-2xl);
    }
  }

  .lien-how-it-works__step {
    text-align: center;
    padding: var(--lien-space-xl) var(--lien-space-lg);
    position: relative;
  }

  .lien-how-it-works__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: var(--lien-cream);
    color: var(--lien-accent);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-lg);
    margin-bottom: var(--lien-space-lg);
    transition: all var(--lien-transition-base);
  }

  .lien-how-it-works__step:hover .lien-how-it-works__number {
    background-color: var(--lien-accent);
    color: var(--lien-white);
    transform: scale(1.05);
  }

  .lien-how-it-works__icon {
    width: 40px;
    height: 40px;
    margin: 0 auto var(--lien-space-md);
    color: var(--lien-accent);
    opacity: 0.7;
  }

  .lien-how-it-works__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .lien-how-it-works__step-title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-lg);
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-sm) 0;
  }

  .lien-how-it-works__step-text {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-sm);
    color: var(--lien-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Connector line between steps (desktop only) */
  @media screen and (min-width: 768px) {
    .lien-how-it-works__step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 46px;
      right: -16px;
      width: 32px;
      height: 1px;
      background-color: var(--lien-border);
    }
  }
{%- endstyle -%}

<section class="lien-how-it-works" id="lien-how-it-works-{{ section.id }}">
  <div class="lien-how-it-works__inner">
    <div class="lien-how-it-works__header">
      {%- if section.settings.label != blank -%}
        <span class="lien-how-it-works__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lien-how-it-works__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-how-it-works__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-how-it-works__grid">
      {%- for block in section.blocks -%}
        <div class="lien-how-it-works__step" {{ block.shopify_attributes }}>
          <div class="lien-how-it-works__number">{{ forloop.index }}</div>

          {%- if block.settings.icon != blank -%}
            <div class="lien-how-it-works__icon">
              {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy' }}
            </div>
          {%- endif -%}

          <h3 class="lien-how-it-works__step-title">{{ block.settings.title }}</h3>
          <p class="lien-how-it-works__step-text">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lien How It Works",
  "tag": "section",
  "class": "lien-how-it-works-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Three simple steps to share something that lasts."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Describe this step in your skincare routine."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Order the Set",
            "description": "Choose your style — black, white, or both. Ships as a complete pair in a premium gift box."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Each Wear One",
            "description": "One bracelet for you, one for them. The magnetic clasp symbolizes your pull toward each other."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Feel the Bond",
            "description": "Wear it daily. A quiet reminder that no matter the distance, you're always connected."
          }
        }
      ]
    }
  ]
}
{% endschema %}
