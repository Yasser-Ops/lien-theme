{%- style -%}
  /* ======================================================================
     Aurelle Offers & Discounts
     Promotional offer cards with discount codes
     ====================================================================== */

  .aurelle-offers {
    background-color: var(--aurelle-dark);
    overflow: hidden;
    position: relative;
  }

  /* Subtle decorative grain overlay */
  .aurelle-offers::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.5;
  }

  .aurelle-offers__inner {
    max-width: var(--aurelle-container-max);
    margin: 0 auto;
    padding: var(--aurelle-section-padding-mobile) var(--aurelle-container-padding-mobile);
    position: relative;
  }

  @media screen and (min-width: 768px) {
    .aurelle-offers__inner {
      padding: var(--aurelle-section-padding-desktop) var(--aurelle-container-padding);
    }
  }

  .aurelle-offers__header {
    text-align: center;
    margin-bottom: var(--aurelle-space-3xl);
  }

  .aurelle-offers__label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aurelle-gold);
    display: block;
    margin-bottom: var(--aurelle-space-sm);
  }

  .aurelle-offers__title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--aurelle-offwhite);
    margin: 0 0 var(--aurelle-space-md) 0;
  }

  .aurelle-offers__subtitle {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-md);
    color: rgba(250, 250, 248, 0.6);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  /* Cards grid */
  .aurelle-offers__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--aurelle-space-lg);
  }

  @media screen and (min-width: 640px) {
    .aurelle-offers__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .aurelle-offers__grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Offer card */
  .aurelle-offers__card {
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--aurelle-space-2xl) var(--aurelle-space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-lg);
    transition: all var(--aurelle-transition-base);
    position: relative;
    overflow: hidden;
  }

  .aurelle-offers__card:hover {
    border-color: rgba(184, 149, 106, 0.3);
    background-color: rgba(255, 255, 255, 0.07);
  }

  /* Featured card accent line */
  .aurelle-offers__card--featured {
    border-color: rgba(184, 149, 106, 0.4);
  }

  .aurelle-offers__card--featured::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--aurelle-gold), var(--aurelle-gold-light));
  }

  /* Card top */
  .aurelle-offers__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--aurelle-space-md);
  }

  .aurelle-offers__offer-label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aurelle-gold);
  }

  .aurelle-offers__badge {
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-sm);
    padding: 6px 14px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* Offer headline */
  .aurelle-offers__offer-title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-xl);
    color: var(--aurelle-offwhite);
    line-height: 1.2;
    margin: 0;
  }

  /* Description */
  .aurelle-offers__offer-text {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-base);
    color: rgba(250, 250, 248, 0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* Discount code block */
  .aurelle-offers__code-block {
    background-color: rgba(184, 149, 106, 0.08);
    border: 1px dashed rgba(184, 149, 106, 0.4);
    padding: var(--aurelle-space-md) var(--aurelle-space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--aurelle-space-md);
    cursor: pointer;
    transition: all var(--aurelle-transition-fast);
  }

  .aurelle-offers__code-block:hover {
    background-color: rgba(184, 149, 106, 0.12);
    border-color: rgba(184, 149, 106, 0.6);
  }

  .aurelle-offers__code {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-lg);
    color: var(--aurelle-gold);
    letter-spacing: 0.08em;
    user-select: all;
  }

  .aurelle-offers__code-hint {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-xs);
    color: rgba(250, 250, 248, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    transition: all var(--aurelle-transition-fast);
  }

  .aurelle-offers__code-hint--copied {
    color: var(--aurelle-gold);
  }

  /* Expiry */
  .aurelle-offers__expiry {
    display: flex;
    align-items: center;
    gap: var(--aurelle-space-xs);
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-xs);
    color: rgba(250, 250, 248, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .aurelle-offers__expiry svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    flex-shrink: 0;
  }

  /* CTA button */
  .aurelle-offers__card-btn {
    display: block;
    text-align: center;
    padding: 14px;
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1.5px solid rgba(184, 149, 106, 0.5);
    color: var(--aurelle-gold);
    background: transparent;
    cursor: pointer;
    transition: all var(--aurelle-transition-base);
    margin-top: auto;
  }

  .aurelle-offers__card-btn:hover {
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
    border-color: var(--aurelle-gold);
  }

  .aurelle-offers__card--featured .aurelle-offers__card-btn {
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
    border-color: var(--aurelle-gold);
  }

  .aurelle-offers__card--featured .aurelle-offers__card-btn:hover {
    background-color: var(--aurelle-gold-hover);
    border-color: var(--aurelle-gold-hover);
  }
{%- endstyle -%}

<section class="aurelle-offers" id="aurelle-offers-{{ section.id }}">
  <div class="aurelle-offers__inner">

    <div class="aurelle-offers__header">
      {%- if section.settings.label != blank -%}
        <span class="aurelle-offers__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="aurelle-offers__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="aurelle-offers__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign grid_class = 'aurelle-offers__grid' -%}
    {%- if section.blocks.size >= 3 -%}
      {%- assign grid_class = 'aurelle-offers__grid aurelle-offers__grid--3' -%}
    {%- endif -%}

    <div class="{{ grid_class }}">
      {%- for block in section.blocks -%}
        <div
          class="aurelle-offers__card{% if block.settings.featured %} aurelle-offers__card--featured{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="aurelle-offers__card-top">
            {%- if block.settings.offer_label != blank -%}
              <span class="aurelle-offers__offer-label">{{ block.settings.offer_label }}</span>
            {%- endif -%}
            {%- if block.settings.badge != blank -%}
              <span class="aurelle-offers__badge">{{ block.settings.badge }}</span>
            {%- endif -%}
          </div>

          <h3 class="aurelle-offers__offer-title">{{ block.settings.title }}</h3>

          {%- if block.settings.description != blank -%}
            <p class="aurelle-offers__offer-text">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.code != blank -%}
            <button
              class="aurelle-offers__code-block"
              type="button"
              data-aurelle-copy-code="{{ block.settings.code }}"
              aria-label="Copy discount code {{ block.settings.code }}"
            >
              <span class="aurelle-offers__code">{{ block.settings.code }}</span>
              <span class="aurelle-offers__code-hint" data-copy-hint>Click to copy</span>
            </button>
          {%- endif -%}

          {%- if block.settings.expiry != blank -%}
            <div class="aurelle-offers__expiry">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {{ block.settings.expiry }}
            </div>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="aurelle-offers__card-btn">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-aurelle-copy-code]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var code = btn.getAttribute('data-aurelle-copy-code');
        var hint = btn.querySelector('[data-copy-hint]');
        navigator.clipboard.writeText(code).then(function () {
          hint.textContent = 'Copied!';
          hint.classList.add('aurelle-offers__code-hint--copied');
          setTimeout(function () {
            hint.textContent = 'Click to copy';
            hint.classList.remove('aurelle-offers__code-hint--copied');
          }, 2000);
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Aurelle Offers",
  "tag": "section",
  "class": "aurelle-offers-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Exclusive Deals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Current Offers"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Limited-time offers to help you start your Aurelle ritual at exceptional value."
    }
  ],
  "blocks": [
    {
      "type": "offer",
      "name": "Offer",
      "settings": [
        {
          "type": "text",
          "id": "offer_label",
          "label": "Offer label (small text above title)",
          "default": "New Customer"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. 20% Off)",
          "info": "Short text displayed as a pill badge. Leave blank to hide."
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured offer",
          "default": false,
          "info": "Adds gold accent line and solid CTA button"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Offer headline",
          "default": "Welcome Gift"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Get 15% off your first order when you use the code below at checkout."
        },
        {
          "type": "text",
          "id": "code",
          "label": "Discount code",
          "default": "AURELLE15",
          "info": "Displayed prominently; visitors can click to copy it"
        },
        {
          "type": "text",
          "id": "expiry",
          "label": "Expiry note",
          "default": "Offer ends Sunday at midnight",
          "info": "Leave blank to hide the expiry line"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aurelle Offers",
      "blocks": [
        {
          "type": "offer",
          "settings": {
            "offer_label": "New Customer",
            "badge": "15% Off",
            "title": "Welcome Gift",
            "description": "Get 15% off your very first order. Enter the code at checkout and experience Aurelle at a special price.",
            "code": "AURELLE15",
            "expiry": "Valid for new customers only",
            "button_label": "Shop Now",
            "featured": false
          }
        },
        {
          "type": "offer",
          "settings": {
            "offer_label": "Limited Time",
            "badge": "Save 25%",
            "featured": true,
            "title": "Bundle Deal",
            "description": "Save 25% when you purchase any bundle. The easiest way to build a complete skincare ritual.",
            "code": "BUNDLE25",
            "expiry": "Offer ends Sunday at midnight",
            "button_label": "Shop Bundles"
          }
        },
        {
          "type": "offer",
          "settings": {
            "offer_label": "Free Gift",
            "badge": "Gift with Purchase",
            "title": "Free Facial Mist",
            "description": "Receive a complimentary Facial Mist (75ml) with any order over $100. No code needed.",
            "expiry": "While stocks last",
