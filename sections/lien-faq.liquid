{%- style -%}
  /* ======================================================================
     Lien FAQ
     Animated accordion Q&A section
     ====================================================================== */

  .lien-faq {
    background-color: var(--lien-offwhite);
  }

  .lien-faq--cream {
    background-color: var(--lien-cream);
  }

  .lien-faq__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-faq__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
    }
  }

  .lien-faq__header {
    text-align: center;
    margin-bottom: var(--lien-space-3xl);
  }

  .lien-faq__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-faq__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-faq__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Layout: single or two-column */
  .lien-faq__body {
    max-width: 800px;
    margin: 0 auto;
  }

  .lien-faq__body--wide {
    max-width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0 var(--lien-space-4xl);
  }

  @media screen and (min-width: 900px) {
    .lien-faq__body--wide {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Individual accordion item */
  .lien-faq__item {
    border-bottom: 1px solid var(--lien-border-light);
  }

  .lien-faq__item:first-child {
    border-top: 1px solid var(--lien-border-light);
  }

  .lien-faq__body--wide .lien-faq__item:first-child,
  .lien-faq__body--wide .lien-faq__item:nth-child(2) {
    border-top: 1px solid var(--lien-border-light);
  }

  /* Question row */
  .lien-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--lien-space-lg);
    padding: var(--lien-space-xl) 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .lien-faq__question::-webkit-details-marker {
    display: none;
  }

  .lien-faq__question-text {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-md);
    color: var(--lien-text);
    line-height: 1.4;
    flex: 1;
    transition: color var(--lien-transition-fast);
  }

  .lien-faq__item[open] .lien-faq__question-text {
    color: var(--lien-accent);
  }

  /* +/- icon */
  .lien-faq__icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    position: relative;
    border: 1.5px solid var(--lien-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--lien-transition-fast);
    color: var(--lien-text-muted);
  }

  .lien-faq__item[open] .lien-faq__icon {
    border-color: var(--lien-accent);
    background-color: var(--lien-accent);
    color: var(--lien-white);
  }

  .lien-faq__icon svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    transition: transform var(--lien-transition-base);
  }

  .lien-faq__icon .lien-faq__icon-minus {
    position: absolute;
    opacity: 0;
    transform: rotate(90deg);
  }

  .lien-faq__item[open] .lien-faq__icon-plus {
    opacity: 0;
    transform: rotate(-90deg);
  }

  .lien-faq__item[open] .lien-faq__icon-minus {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* Answer */
  .lien-faq__answer {
    overflow: hidden;
  }

  .lien-faq__answer-inner {
    padding: 0 0 var(--lien-space-xl) 0;
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    line-height: 1.75;
  }

  .lien-faq__answer-inner p {
    margin: 0 0 var(--lien-space-sm) 0;
  }

  .lien-faq__answer-inner p:last-child {
    margin-bottom: 0;
  }

  .lien-faq__answer-inner a {
    color: var(--lien-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .lien-faq__answer-inner strong {
    color: var(--lien-text);
    font-weight: var(--lien-weight-semibold);
  }

  /* CTA below */
  .lien-faq__cta {
    text-align: center;
    margin-top: var(--lien-space-3xl);
    padding-top: var(--lien-space-3xl);
    border-top: 1px solid var(--lien-border-light);
  }

  .lien-faq__cta-text {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    margin-bottom: var(--lien-space-lg);
  }

  .lien-faq__cta-text a {
    color: var(--lien-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
{%- endstyle -%}

<section
  class="lien-faq{% if section.settings.bg_cream %} lien-faq--cream{% endif %}"
  id="lien-faq-{{ section.id }}"
>
  <div class="lien-faq__inner">

    {%- if section.settings.label != blank or section.settings.heading != blank -%}
      <div class="lien-faq__header">
        {%- if section.settings.label != blank -%}
          <span class="lien-faq__label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="lien-faq__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="lien-faq__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lien-faq__body{% if section.settings.two_column %} lien-faq__body--wide{% endif %}">
      {%- for block in section.blocks -%}
        <details class="lien-faq__item" {{ block.shopify_attributes }}>
          <summary class="lien-faq__question">
            <span class="lien-faq__question-text">{{ block.settings.question }}</span>
            <span class="lien-faq__icon" aria-hidden="true">
              <svg class="lien-faq__icon-plus" viewBox="0 0 24 24">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              <svg class="lien-faq__icon-minus" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </summary>
          <div class="lien-faq__answer">
            <div class="lien-faq__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="lien-faq__cta">
        <p class="lien-faq__cta-text">{{ section.settings.cta_text }}</p>
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link }}" class="lien-btn lien-btn--outline">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Lien FAQ",
  "tag": "section",
  "class": "lien-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Got Questions?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everything you need to know about Lien."
    },
    {
      "type": "checkbox",
      "id": "two_column",
      "label": "Two-column layout (desktop)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "bg_cream",
      "label": "Cream background",
      "default": false
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA message",
      "default": "Still have questions? We're here to help.",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "When will I see results?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most customers notice a visible improvement in skin texture and radiance within 2–4 weeks of consistent use. For deeper concerns like fine lines and uneven tone, allow 6–8 weeks for full results.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>Most customers notice a visible improvement in skin texture and radiance within 2–4 weeks of consistent use. For deeper concerns like fine lines and uneven tone, allow 6–8 weeks for full results.</p>"
          }
        },
