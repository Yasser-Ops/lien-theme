{%- style -%}
  /* ======================================================================
     Lien Featured Product Spotlight
     Hero product — the center of attention
     ====================================================================== */

  .lien-product {
    background-color: var(--lien-offwhite);
  }

  .lien-product__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lien-space-2xl);
  }

  @media screen and (min-width: 1024px) {
    .lien-product__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
      grid-template-columns: 1fr 1fr;
      gap: var(--lien-space-4xl);
      align-items: center;
    }
  }

  /* Product Image */
  .lien-product__media {
    position: relative;
    background-color: var(--lien-cream);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  @media screen and (min-width: 1024px) {
    .lien-product__media {
      aspect-ratio: 4 / 5;
    }
  }

  .lien-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--lien-transition-slow);
  }

  .lien-product__media:hover .lien-product__image {
    transform: scale(1.03);
  }

  .lien-product__badge {
    position: absolute;
    top: var(--lien-space-md);
    left: var(--lien-space-md);
    background-color: var(--lien-accent);
    color: var(--lien-white);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 14px;
    animation: lien-fade-in 0.5s ease 0.3s forwards;
    opacity: 0;
  }

  .lien-product__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, var(--lien-cream) 0%, var(--lien-cream-dark) 100%);
  }

  .lien-product__placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.25;
    color: var(--lien-accent);
  }

  /* Product Info */
  .lien-product__info {
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-lg);
  }

  .lien-product__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
  }

  .lien-product__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0;
  }

  .lien-product__description {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Features list */
  .lien-product__features {
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-sm);
    padding: var(--lien-space-lg) 0;
    border-top: 1px solid var(--lien-border);
    border-bottom: 1px solid var(--lien-border);
  }

  .lien-product__feature {
    display: flex;
    align-items: center;
    gap: var(--lien-space-sm);
  }

  .lien-product__feature-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--lien-accent);
  }

  .lien-product__feature-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .lien-product__feature-text {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-sm);
    color: var(--lien-text-secondary);
  }

  /* Pricing */
  .lien-product__pricing {
    display: flex;
    align-items: baseline;
    gap: var(--lien-space-sm);
  }

  .lien-product__price {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    color: var(--lien-text);
    letter-spacing: -0.01em;
  }

  .lien-product__compare-price {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-product__save-badge {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    color: var(--lien-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    background-color: rgba(123, 143, 166, 0.1);
  }

  /* Add to Cart */
  .lien-product__form {
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-md);
  }

  .lien-product__add-btn {
    width: 100%;
    padding: 18px 40px;
    font-size: var(--lien-text-sm);
  }

  .lien-product__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
{%- endstyle -%}

{%- assign product = section.settings.product -%}

<section class="lien-product" id="lien-product-{{ section.id }}">
  <div class="lien-product__inner">
    {%- comment -%} Product Image {%- endcomment -%}
    <div class="lien-product__media">
      {%- if product != blank and product.featured_image != blank -%}
        {{
          product.featured_image
          | image_url: width: 1200
          | image_tag:
            class: 'lien-product__image',
            loading: 'lazy',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            widths: '375, 550, 750, 1000, 1200'
        }}
      {%- else -%}
        <div class="lien-product__placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
      {%- endif -%}

      {%- if section.settings.badge_text != blank -%}
        <span class="lien-product__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} Product Info {%- endcomment -%}
    <div class="lien-product__info">
      {%- if section.settings.label != blank -%}
        <span class="lien-product__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h2 class="lien-product__title">
        {%- if product != blank -%}
          {{ product.title }}
        {%- else -%}
          {{ section.settings.heading | default: 'Featured Product' }}
        {%- endif -%}
      </h2>

      <p class="lien-product__description">
        {%- if product != blank and product.description != blank -%}
          {{ product.description | strip_html | truncate: 200 }}
        {%- else -%}
          {{ section.settings.description | default: 'A carefully crafted formula designed to nourish and transform your skin.' }}
        {%- endif -%}
      </p>

      {%- comment -%} Feature Bullets (Blocks) {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="lien-product__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature_bullet' -%}
              <div class="lien-product__feature" {{ block.shopify_attributes }}>
                <span class="lien-product__feature-icon">
                  <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="lien-product__feature-text">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Pricing {%- endcomment -%}
      <div class="lien-product__pricing">
        {%- if product != blank -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          <span class="lien-product__price">{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="lien-product__compare-price">{{ current_variant.compare_at_price | money }}</span>
            {%- assign save_amount = current_variant.compare_at_price | minus: current_variant.price -%}
            <span class="lien-product__save-badge">Save {{ save_amount | money }}</span>
          {%- endif -%}
        {%- else -%}
          <span class="lien-product__price">$49.00</span>
          <span class="lien-product__compare-price">$65.00</span>
          <span class="lien-product__save-badge">Save $16.00</span>
        {%- endif -%}
      </div>

      {%- comment -%} Product Link {%- endcomment -%}
{%- if product != blank -%}
  <div class="lien-product__form">
    <a
      href="{{ product.url }}"
      class="lien-btn lien-btn--dark lien-product__add-btn"
    >
      {{ section.settings.button_text | default: 'Get the Set' }}
    </a>
  </div>
{%- else -%}
  <div class="lien-product__form">
    <button class="lien-btn lien-btn--dark lien-product__add-btn" disabled>
      Select a Product
    </button>
  </div>
{%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lien Product Spotlight",
  "tag": "section",
  "class": "lien-product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label above title",
      "default": "The Signature Set"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Magnetic Couple Bracelet Set",
      "info": "Used when no product is selected"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback description",
      "default": "Two bracelets, one connection. Our magnetic heart-charm set is designed for couples who want to carry each other — always."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Best Seller",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to cart button text",
      "default": "Get the Set"
    }
  ],
  "blocks": [
    {
      "type": "feature_bullet",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Magnetic clasp — snaps together like you"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien Product Spotlight",
      "blocks": [
        {
          "type": "feature_bullet",
          "settings": { "text": "Magnetic clasp — snaps together like you" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "Set of 2 — one for each of you" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "Adjustable fit — one size for all" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "Ships in a premium gift box" }
        }
      ]
    }
  ]
}
{% endschema %}
