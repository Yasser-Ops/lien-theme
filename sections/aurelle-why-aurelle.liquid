{%- style -%}
  /* ======================================================================
     Aurelle Why Aurelle
     Dark premium section with card grid
     ====================================================================== */

  .aurelle-why {
    background-color: var(--aurelle-dark);
    overflow: hidden;
  }

  .aurelle-why__inner {
    max-width: var(--aurelle-container-max);
    margin: 0 auto;
    padding: var(--aurelle-section-padding-mobile) var(--aurelle-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .aurelle-why__inner {
      padding: var(--aurelle-section-padding-desktop) var(--aurelle-container-padding);
    }
  }

  .aurelle-why__header {
    text-align: center;
    margin-bottom: var(--aurelle-space-3xl);
  }

  .aurelle-why__label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aurelle-gold);
    display: block;
    margin-bottom: var(--aurelle-space-sm);
  }

  .aurelle-why__title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--aurelle-offwhite);
    margin: 0 0 var(--aurelle-space-md) 0;
  }

  .aurelle-why__subtitle {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-base);
    color: rgba(250, 250, 248, 0.6);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  .aurelle-why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--aurelle-space-lg);
  }

  @media screen and (min-width: 768px) {
    .aurelle-why__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--aurelle-space-xl);
    }
  }

  .aurelle-why__card {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: var(--aurelle-space-2xl) var(--aurelle-space-xl);
    transition: all var(--aurelle-transition-base);
    text-align: center;
  }

  .aurelle-why__card:hover {
    background-color: rgba(255, 255, 255, 0.06);
    border-color: rgba(184, 149, 106, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(184, 149, 106, 0.08);
  }

  .aurelle-why__card-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--aurelle-space-lg);
    color: var(--aurelle-gold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aurelle-why__card-icon svg {
    width: 32px;
    height: 32px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .aurelle-why__card-title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-lg);
    color: var(--aurelle-offwhite);
    margin: 0 0 var(--aurelle-space-sm) 0;
  }

  .aurelle-why__card-text {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-sm);
    color: rgba(250, 250, 248, 0.55);
    line-height: 1.6;
    margin: 0;
  }
{%- endstyle -%}

<section class="aurelle-why" id="aurelle-why-{{ section.id }}">
  <div class="aurelle-why__inner">
    <div class="aurelle-why__header">
      {%- if section.settings.label != blank -%}
        <span class="aurelle-why__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="aurelle-why__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="aurelle-why__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="aurelle-why__grid">
      {%- for block in section.blocks -%}
        <div class="aurelle-why__card" {{ block.shopify_attributes }}>
          <div class="aurelle-why__card-icon">
            {%- case block.settings.icon -%}
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1.68-4.78a16.6 16.6 0 0 0 7.44-.88c3.65-1.47 6.22-4.59 6.22-8.34 0-5-8.78-2-8.78-2"/><path d="M2 2s7.16 1.79 12.93 6.28"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'sparkle' -%}
                <svg viewBox="0 0 24 24"><path d="M12 2L14.09 8.26L20 9.27L15.5 14.14L16.18 21.02L12 17.77L7.82 21.02L8.5 14.14L4 9.27L9.91 8.26L12 2Z"/></svg>
              {%- when 'lab' -%}
                <svg viewBox="0 0 24 24"><path d="M9 3h6v6l5 7.5a2 2 0 0 1-1.7 3H5.7a2 2 0 0 1-1.7-3L9 9V3z"/><path d="M9 3h6"/></svg>
              {%- when 'globe' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            {%- endcase -%}
          </div>

          <h3 class="aurelle-why__card-title">{{ block.settings.title }}</h3>
          <p class="aurelle-why__card-text">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aurelle Why Us",
  "tag": "section",
  "class": "aurelle-why-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Aurelle"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We believe in formulas that work, ingredients that matter, and results you can see."
    }
  ],
  "blocks": [
    {
      "type": "reason_card",
      "name": "Reason",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf / Natural" },
            { "value": "shield", "label": "Shield / Protection" },
            { "value": "heart", "label": "Heart / Care" },
            { "value": "sparkle", "label": "Sparkle / Results" },
            { "value": "lab", "label": "Lab / Science" },
            { "value": "globe", "label": "Globe / Sustainable" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Clean Ingredients"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every formula is crafted with naturally-derived, ethically-sourced ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aurelle Why Us",
      "blocks": [
        {
          "type": "reason_card",
          "settings": {
            "icon": "leaf",
            "title": "Clean Ingredients",
            "description": "Every formula is crafted with naturally-derived, ethically-sourced ingredients."
          }
        },
        {
          "type": "reason_card",
          "settings": {
            "icon": "lab",
            "title": "Clinically Tested",
            "description": "Backed by science and validated through rigorous dermatological testing."
          }
        },
        {
          "type": "reason_card",
          "settings": {
            "icon": "globe",
            "title": "Sustainably Made",
            "description": "Eco-conscious packaging and cruelty-free practices from formulation to delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
