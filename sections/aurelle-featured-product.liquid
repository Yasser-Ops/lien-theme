{%- style -%}
  /* ======================================================================
     Aurelle Featured Product Spotlight
     Hero product — the center of attention
     ====================================================================== */

  .aurelle-product {
    background-color: var(--aurelle-offwhite);
  }

  .aurelle-product__inner {
    max-width: var(--aurelle-container-max);
    margin: 0 auto;
    padding: var(--aurelle-section-padding-mobile) var(--aurelle-container-padding-mobile);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--aurelle-space-2xl);
  }

  @media screen and (min-width: 1024px) {
    .aurelle-product__inner {
      padding: var(--aurelle-section-padding-desktop) var(--aurelle-container-padding);
      grid-template-columns: 1fr 1fr;
      gap: var(--aurelle-space-4xl);
      align-items: center;
    }
  }

  /* Product Image */
  .aurelle-product__media {
    position: relative;
    background-color: var(--aurelle-cream);
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  @media screen and (min-width: 1024px) {
    .aurelle-product__media {
      aspect-ratio: 4 / 5;
    }
  }

  .aurelle-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--aurelle-transition-slow);
  }

  .aurelle-product__media:hover .aurelle-product__image {
    transform: scale(1.03);
  }

  .aurelle-product__badge {
    position: absolute;
    top: var(--aurelle-space-md);
    left: var(--aurelle-space-md);
    background-color: var(--aurelle-gold);
    color: var(--aurelle-white);
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 14px;
    animation: aurelle-fade-in 0.5s ease 0.3s forwards;
    opacity: 0;
  }

  .aurelle-product__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, var(--aurelle-cream) 0%, var(--aurelle-cream-dark) 100%);
  }

  .aurelle-product__placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.25;
    color: var(--aurelle-gold);
  }

  /* Product Info */
  .aurelle-product__info {
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-lg);
  }

  .aurelle-product__label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aurelle-gold);
  }

  .aurelle-product__title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--aurelle-text);
    margin: 0;
  }

  .aurelle-product__description {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-base);
    color: var(--aurelle-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Features list */
  .aurelle-product__features {
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-sm);
    padding: var(--aurelle-space-lg) 0;
    border-top: 1px solid var(--aurelle-border);
    border-bottom: 1px solid var(--aurelle-border);
  }

  .aurelle-product__feature {
    display: flex;
    align-items: center;
    gap: var(--aurelle-space-sm);
  }

  .aurelle-product__feature-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--aurelle-gold);
  }

  .aurelle-product__feature-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .aurelle-product__feature-text {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-sm);
    color: var(--aurelle-text-secondary);
  }

  /* Pricing */
  .aurelle-product__pricing {
    display: flex;
    align-items: baseline;
    gap: var(--aurelle-space-sm);
  }

  .aurelle-product__price {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-bold);
    font-size: var(--aurelle-text-2xl);
    color: var(--aurelle-text);
    letter-spacing: -0.01em;
  }

  .aurelle-product__compare-price {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-md);
    color: var(--aurelle-text-muted);
    text-decoration: line-through;
  }

  .aurelle-product__save-badge {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    color: var(--aurelle-gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    background-color: rgba(184, 149, 106, 0.1);
  }

  /* Add to Cart */
  .aurelle-product__form {
    display: flex;
    flex-direction: column;
    gap: var(--aurelle-space-md);
  }

  .aurelle-product__add-btn {
    width: 100%;
    padding: 18px 40px;
    font-size: var(--aurelle-text-sm);
  }

  .aurelle-product__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
{%- endstyle -%}

{%- assign product = section.settings.product -%}

<section class="aurelle-product" id="aurelle-product-{{ section.id }}">
  <div class="aurelle-product__inner">
    {%- comment -%} Product Image {%- endcomment -%}
    <div class="aurelle-product__media">
      {%- if product != blank and product.featured_image != blank -%}
        {{
          product.featured_image
          | image_url: width: 1200
          | image_tag:
            class: 'aurelle-product__image',
            loading: 'lazy',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            widths: '375, 550, 750, 1000, 1200'
        }}
      {%- else -%}
        <div class="aurelle-product__placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
      {%- endif -%}

      {%- if section.settings.badge_text != blank -%}
        <span class="aurelle-product__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} Product Info {%- endcomment -%}
    <div class="aurelle-product__info">
      {%- if section.settings.label != blank -%}
        <span class="aurelle-product__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h2 class="aurelle-product__title">
        {%- if product != blank -%}
          {{ product.title }}
        {%- else -%}
          {{ section.settings.heading | default: 'Featured Product' }}
        {%- endif -%}
      </h2>

      <p class="aurelle-product__description">
        {%- if product != blank and product.description != blank -%}
          {{ product.description | strip_html | truncate: 200 }}
        {%- else -%}
          {{ section.settings.description | default: 'A carefully crafted formula designed to nourish and transform your skin.' }}
        {%- endif -%}
      </p>

      {%- comment -%} Feature Bullets (Blocks) {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="aurelle-product__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature_bullet' -%}
              <div class="aurelle-product__feature" {{ block.shopify_attributes }}>
                <span class="aurelle-product__feature-icon">
                  <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="aurelle-product__feature-text">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Pricing {%- endcomment -%}
      <div class="aurelle-product__pricing">
        {%- if product != blank -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          <span class="aurelle-product__price">{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="aurelle-product__compare-price">{{ current_variant.compare_at_price | money }}</span>
            {%- assign save_amount = current_variant.compare_at_price | minus: current_variant.price -%}
            <span class="aurelle-product__save-badge">Save {{ save_amount | money }}</span>
          {%- endif -%}
        {%- else -%}
          <span class="aurelle-product__price">$49.00</span>
          <span class="aurelle-product__compare-price">$65.00</span>
          <span class="aurelle-product__save-badge">Save $16.00</span>
        {%- endif -%}
      </div>

      {%- comment -%} Add to Cart {%- endcomment -%}
      {%- if product != blank -%}
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        <div class="aurelle-product__form">
          <product-form data-section-id="{{ section.id }}">
            {%- form 'product', product, id: 'aurelle-product-form', novalidate: 'novalidate' -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <button
                type="submit"
                name="add"
                class="aurelle-btn aurelle-btn--dark aurelle-product__add-btn"
                {%- unless current_variant.available -%}disabled{%- endunless -%}
              >
                {%- if current_variant.available -%}
                  {{ section.settings.button_text | default: 'Add to Cart' }}
                {%- else -%}
                  Sold Out
                {%- endif -%}
              </button>
            {%- endform -%}
          </product-form>
        </div>
      {%- else -%}
        <div class="aurelle-product__form">
          <button class="aurelle-btn aurelle-btn--dark aurelle-product__add-btn" disabled>
            Select a Product
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aurelle Product Spotlight",
  "tag": "section",
  "class": "aurelle-product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label above title",
      "default": "Our Bestseller"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Featured Product",
      "info": "Used when no product is selected"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback description",
      "default": "A carefully crafted formula designed to nourish and transform your skin."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Bestseller",
      "info": "Leave blank to hide"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add to cart button text",
      "default": "Add to Cart"
    }
  ],
  "blocks": [
    {
      "type": "feature_bullet",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Clinically proven results"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aurelle Product Spotlight",
      "blocks": [
        {
          "type": "feature_bullet",
          "settings": { "text": "Clinically proven results in 4 weeks" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "100% natural, clean ingredients" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "Suitable for all skin types" }
        },
        {
          "type": "feature_bullet",
          "settings": { "text": "Cruelty-free & vegan formula" }
        }
      ]
    }
  ]
}
{% endschema %}
