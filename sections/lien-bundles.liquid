{%- style -%}
  /* ======================================================================
     Lien Bundles
     Visual bundle showcase — buttons redirect to product page where
     Pumper Bundles handles the actual purchase flow
     ====================================================================== */

  .lien-bundles {
    background-color: var(--lien-cream);
  }

  .lien-bundles__inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile);
  }

  @media screen and (min-width: 768px) {
    .lien-bundles__inner {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding);
    }
  }

  .lien-bundles__header {
    text-align: center;
    margin-bottom: var(--lien-space-3xl);
  }

  .lien-bundles__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-bundles__title {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-text);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-bundles__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Grid */
  .lien-bundles__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lien-space-lg);
    align-items: start;
  }

  @media screen and (min-width: 640px) {
    .lien-bundles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .lien-bundles__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .lien-bundles__card {
    background-color: var(--lien-white);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all var(--lien-transition-base);
  }

  .lien-bundles__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--lien-shadow-lg);
  }

  .lien-bundles__card--featured {
    border: 2px solid var(--lien-accent);
    transform: scale(1.02);
  }

  .lien-bundles__card--featured:hover {
    transform: scale(1.02) translateY(-4px);
  }

  /* Badge */
  .lien-bundles__badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--lien-accent);
    color: var(--lien-white);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    white-space: nowrap;
  }

  /* Image */
  .lien-bundles__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--lien-cream);
  }

  .lien-bundles__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--lien-transition-slow);
  }

  .lien-bundles__card:hover .lien-bundles__image img {
    transform: scale(1.03);
  }

  .lien-bundles__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--lien-cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lien-text-muted);
  }

  .lien-bundles__image-placeholder svg {
    width: 48px;
    height: 48px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1;
    opacity: 0.4;
  }

  /* Body */
  .lien-bundles__body {
    padding: var(--lien-space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-md);
  }

  .lien-bundles__name {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-xl);
    color: var(--lien-text);
    margin: 0;
    line-height: 1.2;
  }

  .lien-bundles__description {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Items list */
  .lien-bundles__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-xs);
    padding-top: var(--lien-space-sm);
    border-top: 1px solid var(--lien-border-light);
  }

  .lien-bundles__item {
    display: flex;
    align-items: center;
    gap: var(--lien-space-sm);
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    color: var(--lien-text-secondary);
  }

  .lien-bundles__item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--lien-accent);
    flex-shrink: 0;
  }

  /* Pricing */
  .lien-bundles__pricing {
    display: flex;
    align-items: center;
    gap: var(--lien-space-md);
    flex-wrap: wrap;
  }

  .lien-bundles__price {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-2xl);
    color: var(--lien-dark);
  }

  .lien-bundles__price-original {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: var(--lien-text-muted);
    text-decoration: line-through;
  }

  .lien-bundles__savings {
    background-color: rgba(123, 143, 166, 0.12);
    color: var(--lien-accent);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: var(--lien-radius-sm);
  }

  /* CTA */
  .lien-bundles__cta {
    margin-top: auto;
  }

  .lien-bundles__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 16px;
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all var(--lien-transition-base);
  }

  .lien-bundles__btn--gold {
    background-color: var(--lien-accent);
    color: var(--lien-white);
  }

  .lien-bundles__btn--gold:hover {
    background-color: var(--lien-accent-hover);
  }

  .lien-bundles__btn--dark {
    background-color: var(--lien-dark);
    color: var(--lien-white);
  }

  .lien-bundles__btn--dark:hover {
    background-color: var(--lien-dark-hover);
  }
{%- endstyle -%}

{%- assign bundle_product = section.settings.product -%}

<section class="lien-bundles" id="lien-bundles-{{ section.id }}">
  <div class="lien-bundles__inner">

    <div class="lien-bundles__header">
      {%- if section.settings.label != blank -%}
        <span class="lien-bundles__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="lien-bundles__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="lien-bundles__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="lien-bundles__grid">
      {%- for block in section.blocks -%}
        {%- assign btn_style = 'dark' -%}
        {%- if block.settings.featured -%}{%- assign btn_style = 'gold' -%}{%- endif -%}

        {%- comment -%} Build the product page URL with bundle quantity param for Pumper auto-select {%- endcomment -%}
        {%- if bundle_product != blank -%}
          {%- assign card_url = bundle_product.url | append: '?bundle=' | append: block.settings.bundle_qty | append: '#pumper-widget' -%}
        {%- else -%}
          {%- assign card_url = block.settings.custom_link | default: '#' -%}
        {%- endif -%}

        <div
          class="lien-bundles__card{% if block.settings.featured %} lien-bundles__card--featured{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.badge != blank -%}
            <div class="lien-bundles__badge">{{ block.settings.badge }}</div>
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            <div class="lien-bundles__image">
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw'
              }}
            </div>
          {%- else -%}
            <div class="lien-bundles__image-placeholder">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {%- endif -%}

          <div class="lien-bundles__body">
            <h3 class="lien-bundles__name">{{ block.settings.name }}</h3>

            {%- if block.settings.description != blank -%}
              <p class="lien-bundles__description">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if block.settings.items != blank -%}
              <ul class="lien-bundles__items">
                {%- assign items_list = block.settings.items | split: ',' -%}
                {%- for item in items_list -%}
                  <li class="lien-bundles__item">
                    <span class="lien-bundles__item-dot"></span>
                    {{ item | strip }}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="lien-bundles__pricing">
              <span class="lien-bundles__price">{{ block.settings.price }}</span>
              {%- if block.settings.original_price != blank -%}
                <span class="lien-bundles__price-original">{{ block.settings.original_price }}</span>
              {%- endif -%}
              {%- if block.settings.savings_label != blank -%}
                <span class="lien-bundles__savings">{{ block.settings.savings_label }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.button_label != blank -%}
              <div class="lien-bundles__cta">
                <a href="{{ card_url }}" class="lien-bundles__btn lien-bundles__btn--{{ btn_style }}">
                  {{ block.settings.button_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Lien Bundles",
  "tag": "section",
  "class": "lien-bundles-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Links each bundle card to this product's page. Pumper Bundles on the product page handles the actual purchase."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Save More"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bundle & Save"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The more love you share, the more you save."
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bundle image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "info": "e.g. Most Popular — leave blank to hide"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured",
          "default": false,
          "info": "Adds gold border and gold button"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Bundle name",
          "default": "1 Set"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Included items (comma-separated)",
          "info": "e.g. 2 × Magnetic Couple Bracelet Set, Premium gift box"
        },
        {
          "type": "number",
          "id": "bundle_qty",
          "label": "Bundle quantity",
          "default": 1,
          "info": "Passed as ?bundle=N in the URL so Pumper can auto-select the right offer"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Display price",
          "default": "$20",
          "info": "Match this to what you configured in Pumper"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original price (crossed out)",
          "info": "Leave blank to hide"
        },
        {
          "type": "text",
          "id": "savings_label",
          "label": "Savings label",
          "info": "e.g. Save $5 — leave blank to hide"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Get this Bundle"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link",
          "info": "Overrides the auto-generated product link. Use only if no product is selected above."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lien Bundles",
      "blocks": [
        {
          "type": "bundle",
          "settings": {
            "name": "1 Set",
            "description": "One complete pair for the two of you. The perfect start to your Lien story.",
            "items": "2 bracelets, Premium gift box",
            "bundle_qty": 1,
            "price": "$20",
            "button_label": "Get 1 Set",
            "featured": false
          }
        },
        {
          "type": "bundle",
          "settings": {
            "badge": "Most Popular",
            "name": "2 Sets",
            "description": "Keep one, gift one. Perfect for couples and best friends.",
            "items": "4 bracelets, 2 premium gift boxes",
            "bundle_qty": 2,
            "price": "$35",
            "original_price": "$40",
            "savings_label": "Save $5",
            "button_label": "Get 2 Sets",
            "featured": true
          }
        },
        {
          "type": "bundle",
          "settings": {
            "badge": "Best Value",
            "name": "3 Sets",
            "description": "Share the love. Biggest saving per set.",
            "items": "6 bracelets, 3 premium gift boxes",
            "bundle_qty": 3,
            "price": "$48",
            "original_price": "$60",
            "savings_label": "Save $12",
            "button_label": "Get 3 Sets",
            "featured": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
