{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{%- style -%}
  /* ======================================================================
     Lien Footer
     Dark editorial footer - newsletter + links + copyright
     ====================================================================== */

  .lien-footer {
    background-color: var(--lien-offwhite);
    position: relative;
    overflow: hidden;
  }

  /* Decorative gradient glow */
  .lien-footer::before {
    content: '';
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(123, 143, 166, 0.05) 0%, transparent 70%);
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  /* ---- Newsletter block ---- */
  .lien-footer__newsletter {
    max-width: 640px;
    margin: 0 auto;
    padding: var(--lien-section-padding-mobile) var(--lien-container-padding-mobile) var(--lien-space-3xl);
    text-align: center;
    position: relative;
  }

  @media screen and (min-width: 768px) {
    .lien-footer__newsletter {
      padding: var(--lien-section-padding-desktop) var(--lien-container-padding) var(--lien-space-3xl);
    }
  }

  .lien-footer__label {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--lien-accent);
    display: block;
    margin-bottom: var(--lien-space-sm);
  }

  .lien-footer__heading {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-bold);
    font-size: var(--lien-text-3xl);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--lien-dark);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-footer__subtitle {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-md);
    color: rgba(18, 18, 16, 0.55);
    line-height: 1.7;
    margin: 0 auto var(--lien-space-2xl);
    max-width: 440px;
  }

  .lien-footer__form {
    display: flex;
    gap: 0;
    max-width: 480px;
    margin: 0 auto;
  }

  @media screen and (max-width: 480px) {
    .lien-footer__form {
      flex-direction: column;
      gap: var(--lien-space-sm);
    }
  }

  .lien-footer__input {
    flex: 1;
    padding: 1.6rem 2rem;
    background-color: rgba(18, 18, 16, 0.06);
    border: 1px solid rgba(18, 18, 16, 0.12);
    border-right: none;
    color: var(--lien-dark);
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-base);
    outline: none;
    transition: border-color var(--lien-transition-fast);
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }

  @media screen and (max-width: 480px) {
    .lien-footer__input { border-right: 1px solid rgba(18, 18, 16, 0.12); }
  }

  .lien-footer__input::placeholder { color: rgba(18, 18, 16, 0.35); }

  .lien-footer__input:focus {
    border-color: var(--lien-accent);
    background-color: rgba(18, 18, 16, 0.09);
  }

  .lien-footer__submit {
    padding: 1.6rem 2.8rem;
    background-color: var(--lien-accent);
    color: var(--lien-white);
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    cursor: pointer;
    transition: background-color var(--lien-transition-fast);
    white-space: nowrap;
    border-radius: 0;
    flex-shrink: 0;
  }

  .lien-footer__submit:hover { background-color: var(--lien-accent-hover); }

  .lien-footer__success {
    display: none;
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-sm);
    color: var(--lien-dark);
    margin-top: var(--lien-space-md);
  }

  .lien-footer__success.is-visible { display: block; }

  .lien-footer__privacy {
    margin-top: var(--lien-space-md);
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: rgba(18, 18, 16, 0.3);
  }

  .lien-footer__privacy a {
    color: rgba(18, 18, 16, 0.5);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ---- Middle: links + social ---- */
  .lien-footer__middle {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-space-2xl) var(--lien-container-padding-mobile);
    border-top: 1px solid rgba(18, 18, 16, 0.07);
    display: flex;
    flex-wrap: wrap;
    gap: var(--lien-space-2xl);
    justify-content: center;
    position: relative;
  }

  @media screen and (min-width: 768px) {
    .lien-footer__middle {
      padding: var(--lien-space-2xl) var(--lien-container-padding);
      justify-content: space-between;
    }
  }

  .lien-footer__col-heading {
    font-family: var(--lien-font-heading);
    font-weight: var(--lien-weight-semibold);
    font-size: var(--lien-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(18, 18, 16, 0.45);
    margin: 0 0 var(--lien-space-md) 0;
  }

  .lien-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--lien-space-sm);
  }

  .lien-footer__links a {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-sm);
    color: rgba(18, 18, 16, 0.6);
    text-decoration: none;
    transition: color var(--lien-transition-fast);
  }

  .lien-footer__links a:hover { color: var(--lien-dark); }

  .lien-footer__social {
    display: flex;
    gap: var(--lien-space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  .lien-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(18, 18, 16, 0.12);
    color: rgba(18, 18, 16, 0.5);
    text-decoration: none;
    transition: all var(--lien-transition-fast);
  }

  .lien-footer__social a:hover {
    border-color: var(--lien-accent);
    color: var(--lien-dark);
  }

  .lien-footer__social svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  /* ---- Bottom bar ---- */
  .lien-footer__bottom {
    border-top: 1px solid rgba(18, 18, 16, 0.07);
    position: relative;
  }

  .lien-footer__bottom-inner {
    max-width: var(--lien-container-max);
    margin: 0 auto;
    padding: var(--lien-space-lg) var(--lien-container-padding-mobile);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--lien-space-md);
  }

  @media screen and (min-width: 768px) {
    .lien-footer__bottom-inner { padding: var(--lien-space-lg) var(--lien-container-padding); }
  }

  .lien-footer__copyright {
    font-family: var(--lien-font-body);
    font-size: var(--lien-text-xs);
    color: rgba(18, 18, 16, 0.3);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--lien-space-md);
  }

  .lien-footer__copyright a {
    color: rgba(18, 18, 16, 0.4);
    text-decoration: none;
    transition: color var(--lien-transition-fast);
  }

  .lien-footer__copyright a:hover { color: rgba(18, 18, 16, 0.7); }

  .lien-footer__policies {
    display: flex;
    flex-wrap: wrap;
    gap: var(--lien-space-md);
  }

  .lien-footer__payment {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .lien-footer__payment .icon {
    height: 20px;
    width: auto;
    opacity: 0.5;
    filter: brightness(0);
  }
{%- endstyle -%}

{%- liquid
  assign has_social = false
  if settings.social_instagram_link != blank or settings.social_tiktok_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_youtube_link != blank
    assign has_social = true
  endif
-%}

<footer class="lien-footer">

  {%- if section.settings.newsletter_enable -%}
  <div class="lien-footer__newsletter">
    {%- if section.settings.newsletter_label != blank -%}
      <span class="lien-footer__label">{{ section.settings.newsletter_label }}</span>
    {%- endif -%}

    <h2 class="lien-footer__heading">{{ section.settings.newsletter_heading }}</h2>

    {%- if section.settings.newsletter_subtitle != blank -%}
      <p class="lien-footer__subtitle">{{ section.settings.newsletter_subtitle }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'lien-footer-form-{{ section.id }}', class: 'lien-footer__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        class="lien-footer__input"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email address' }}"
        required
        autocomplete="email"
        aria-label="{{ section.settings.newsletter_placeholder | default: 'Your email address' }}"
      >
      <button type="submit" class="lien-footer__submit">
        {{ section.settings.newsletter_btn | default: 'Subscribe' }}
      </button>
      {%- if form.posted_successfully? -%}
        <p class="lien-footer__success is-visible">
          {{ section.settings.newsletter_success | default: 'Thank you - welcome to the Lien family.' }}
        </p>
      {%- endif -%}
    {%- endform -%}

    <p class="lien-footer__privacy">We respect your privacy. Unsubscribe at any time.</p>
  </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 or has_social -%}
  <div class="lien-footer__middle">
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' and block.settings.menu != blank -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p class="lien-footer__col-heading">{{ block.settings.heading }}</p>
          {%- endif -%}
          <ul class="lien-footer__links">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- elsif block.type == 'text' -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p class="lien-footer__col-heading">{{ block.settings.heading }}</p>
          {%- endif -%}
          <div class="lien-footer__links" style="color:rgba(18,18,16,0.6);font-family:var(--lien-font-body);font-size:var(--lien-text-sm);line-height:1.7;">
            {{ block.settings.subtext }}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- if has_social -%}
      <div>
        <p class="lien-footer__col-heading">Follow Us</p>
        <div class="lien-footer__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.16 8.16 0 0 0 4.78 1.53V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}
            <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest">
              <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
  {%- endif -%}

  <div class="lien-footer__bottom">
    <div class="lien-footer__bottom-inner">
      <div class="lien-footer__copyright">
        <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
        {%- if section.settings.show_policy -%}
          <div class="lien-footer__policies">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      {%- if section.settings.payment_enable -%}
        <div class="lien-footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Show newsletter signup"
    },
    {
      "type": "text",
      "id": "newsletter_label",
      "label": "Label",
      "default": "Join the Community"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Stay Close, Stay Connected"
    },
    {
      "type": "textarea",
      "id": "newsletter_subtitle",
      "label": "Subtitle",
      "default": "Get exclusive offers, new arrivals, and couple stories. No spam - ever."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "newsletter_btn",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "newsletter_success",
      "label": "Success message",
      "default": "Thank you - welcome to the Lien family."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label"
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" }
    ]
  }
}
{% endschema %}
