{{ 'aurelle-base.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ======================================================================
     Aurelle Hero Section
     Split layout: image left, content right
     ====================================================================== */

  .aurelle-hero {
    background-color: var(--aurelle-offwhite);
    overflow: hidden;
  }

  .aurelle-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 85vh;
  }

  @media screen and (min-width: 1024px) {
    .aurelle-hero__inner {
      grid-template-columns: 1fr 1fr;
      min-height: 90vh;
    }
  }

  /* Image side */
  .aurelle-hero__media {
    position: relative;
    overflow: hidden;
    min-height: 50vh;
    background-color: var(--aurelle-cream);
  }

  @media screen and (min-width: 1024px) {
    .aurelle-hero__media {
      min-height: auto;
    }
  }

  .aurelle-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .aurelle-hero__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, var(--aurelle-cream) 0%, var(--aurelle-cream-dark) 100%);
  }

  .aurelle-hero__placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
    color: var(--aurelle-gold);
  }

  /* Content side */
  .aurelle-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--aurelle-space-2xl) var(--aurelle-container-padding-mobile);
  }

  @media screen and (min-width: 1024px) {
    .aurelle-hero__content {
      padding: var(--aurelle-space-4xl) var(--aurelle-space-4xl);
      padding-right: var(--aurelle-space-3xl);
    }
  }

  .aurelle-hero__label {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-semibold);
    font-size: var(--aurelle-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aurelle-gold);
    margin-bottom: var(--aurelle-space-lg);
    opacity: 0;
    animation: aurelle-fade-in 0.6s ease 0.2s forwards;
  }

  .aurelle-hero__title {
    font-family: var(--aurelle-font-heading);
    font-weight: var(--aurelle-weight-extrabold);
    font-size: var(--aurelle-text-4xl);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--aurelle-text);
    margin: 0 0 var(--aurelle-space-lg) 0;
    opacity: 0;
    animation: aurelle-fade-in 0.7s ease 0.3s forwards;
  }

  @media screen and (min-width: 1024px) {
    .aurelle-hero__title {
      font-size: var(--aurelle-text-5xl);
    }
  }

  .aurelle-hero__subtitle {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-md);
    color: var(--aurelle-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--aurelle-space-xl) 0;
    max-width: 480px;
    opacity: 0;
    animation: aurelle-fade-in 0.7s ease 0.4s forwards;
  }

  .aurelle-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--aurelle-space-md);
    margin-bottom: var(--aurelle-space-2xl);
    opacity: 0;
    animation: aurelle-fade-in 0.7s ease 0.5s forwards;
  }

  .aurelle-hero__proof {
    display: flex;
    align-items: center;
    gap: var(--aurelle-space-sm);
    opacity: 0;
    animation: aurelle-fade-in 0.7s ease 0.6s forwards;
  }

  .aurelle-hero__proof-stars {
    display: flex;
    gap: 2px;
    color: var(--aurelle-gold);
  }

  .aurelle-hero__proof-stars svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .aurelle-hero__proof-text {
    font-family: var(--aurelle-font-body);
    font-size: var(--aurelle-text-sm);
    color: var(--aurelle-text-muted);
  }
{%- endstyle -%}

<section class="aurelle-hero" id="aurelle-hero-{{ section.id }}">
  <div class="aurelle-hero__inner">
    {%- comment -%} Image Side {%- endcomment -%}
    <div class="aurelle-hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'aurelle-hero__image',
            loading: 'eager',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            widths: '375, 550, 750, 1000, 1200'
        }}
      {%- else -%}
        <div class="aurelle-hero__placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Content Side {%- endcomment -%}
    <div class="aurelle-hero__content">
      {%- if section.settings.label != blank -%}
        <span class="aurelle-hero__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <h1 class="aurelle-hero__title">{{ section.settings.heading }}</h1>

      {%- if section.settings.subtitle != blank -%}
        <p class="aurelle-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="aurelle-hero__actions">
        {%- if section.settings.button_label_1 != blank -%}
          <a href="{{ section.settings.button_link_1 }}" class="aurelle-btn aurelle-btn--gold">
            {{ section.settings.button_label_1 }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="aurelle-btn aurelle-btn--outline">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_social_proof -%}
        <div class="aurelle-hero__proof">
          <div class="aurelle-hero__proof-stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <span class="aurelle-hero__proof-text">{{ section.settings.social_proof_text }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Aurelle Hero",
  "tag": "section",
  "class": "aurelle-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Premium Skincare"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Reveal Your Natural Radiance"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Carefully crafted formulas that nourish, protect, and transform your skin with nature's finest ingredients."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "checkbox",
      "id": "show_social_proof",
      "label": "Show social proof",
      "default": true
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Social proof text",
      "default": "Trusted by 10,000+ customers"
    }
  ],
  "presets": [
    {
      "name": "Aurelle Hero"
    }
  ]
}
{% endschema %}
