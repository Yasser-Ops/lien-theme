      "default": "Added to cart successfully!"
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Unable to add to cart. Please try again."
    },
    {
      "type": "color",
      "id": "success_bg_color",
      "label": "Success background color",
      "default": "#B8956A"
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Success text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "error_bg_color",
      "label": "Error background color",
      "default": "#D82C0D"
    },
    {
      "type": "color",
      "id": "error_text_color",
      "label": "Error text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "AJAX add to cart button"
    }
  ]
