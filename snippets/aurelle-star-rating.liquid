{%- comment -%}
  Lien Star Rating Snippet
  Usage: {% render 'lien-star-rating', rating: 5, size: 'md' %}
  
  Parameters:
    rating - Number 1-5 (required)
    size   - 'sm' (14px), 'md' (16px), 'lg' (20px) (default: 'md')
{%- endcomment -%}

{%- liquid
  assign star_size = '16'
  case size
    when 'sm'
      assign star_size = '14'
    when 'lg'
      assign star_size = '20'
  endcase
  assign rating_val = rating | default: 5 | round
-%}

<div class="lien-stars" role="img" aria-label="{{ rating_val }} out of 5 stars" style="display:inline-flex;gap:2px;">
  {%- for i in (1..5) -%}
    {%- if i <= rating_val -%}
      <svg width="{{ star_size }}" height="{{ star_size }}" viewBox="0 0 24 24" fill="#B8956A" stroke="none">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- else -%}
      <svg width="{{ star_size }}" height="{{ star_size }}" viewBox="0 0 24 24" fill="#E8E4DF" stroke="none">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- endif -%}
  {%- endfor -%}
</div>
