{%- comment -%}
  Lien Icon Snippet
  Usage: {% render 'lien-icon', icon: 'shipping', size: 24 %}
  
  Parameters:
    icon  - Icon name (required)
    size  - Pixel size (default: 24)
    color - CSS color value (optional, default: currentColor)
  
  Available icons:
    shipping, shield, lock, leaf, check, star, heart, sparkle,
    lab, globe, truck, arrow-right, plus, minus, close
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 24
  assign icon_color = color | default: 'currentColor'
-%}

<svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {%- case icon -%}
    {%- when 'shipping' or 'truck' -%}
      <path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>

    {%- when 'shield' or 'guarantee' -%}
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>

    {%- when 'lock' or 'secure' -%}
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>

    {%- when 'leaf' or 'natural' -%}
      <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1.68-4.78a16.6 16.6 0 0 0 7.44-.88c3.65-1.47 6.22-4.59 6.22-8.34 0-5-8.78-2-8.78-2"/><path d="M2 2s7.16 1.79 12.93 6.28"/>

    {%- when 'check' or 'certified' -%}
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>

    {%- when 'star' -%}
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{{ icon_color }}" stroke="none"/>

    {%- when 'heart' -%}
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>

    {%- when 'sparkle' -%}
      <path d="M12 2L14.09 8.26L20 9.27L15.5 14.14L16.18 21.02L12 17.77L7.82 21.02L8.5 14.14L4 9.27L9.91 8.26L12 2Z"/>

    {%- when 'lab' -%}
      <path d="M9 3h6v6l5 7.5a2 2 0 0 1-1.7 3H5.7a2 2 0 0 1-1.7-3L9 9V3z"/><path d="M9 3h6"/>

    {%- when 'globe' -%}
      <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>

    {%- when 'arrow-right' -%}
      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>

    {%- when 'plus' -%}
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>

    {%- when 'minus' -%}
      <line x1="5" y1="12" x2="19" y2="12"/>

    {%- when 'close' -%}
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>

    {%- else -%}
      <circle cx="12" cy="12" r="10"/>
  {%- endcase -%}
</svg>
