        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Can I use Aurelle with other products?",
            "answer": "<p>Absolutely. Aurelle layers well with other skincare. Apply after cleansing and toning, before heavier creams and oils. Always finish with SPF in the morning.</p>"
          }
        },
