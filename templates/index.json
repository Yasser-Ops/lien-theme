    "lien_faq": {
      "type": "lien-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What's included in the set?",
            "answer": "<p>Each Lien set includes 2 bracelets — one black cord and one white cord, both with a matching magnetic heart charm. They arrive in a premium gift box, ready to give or keep.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "How does the magnetic clasp work?",
            "answer": "<p>Each bracelet has a small magnetic tip. When the two bracelets are brought close together, they snap together instantly. It's a symbolic reminder that no matter how far apart you are, you're always drawn to each other.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Is it adjustable? Will it fit?",
            "answer": "<p>Yes — both bracelets are fully adjustable with a sliding knot design. They fit all wrist sizes comfortably and can be loosened or tightened in seconds.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Can I wear it in the shower or swimming?",
            "answer": "<p>The cord is water-resistant and designed for daily wear. We recommend removing it before prolonged water exposure (like swimming) to preserve the cord's quality over time.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a <strong>30-day money-back guarantee</strong>. If you're not completely satisfied, contact us within 30 days for a full refund — no questions asked.</p>"
          }
        },
        "faq_6": {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders are processed within 1–2 business days. Standard shipping takes 5–10 days worldwide. Expedited options are available at checkout.</p>"
          }
        }
      },
