          "type": "faq_item",
          "settings": {
            "question": "Is the formula cruelty-free and vegan?",
            "answer": "<p>Yes — Aurelle is 100% cruelty-free and vegan certified. We never test on animals and none of our ingredients are derived from animal sources.</p>"
